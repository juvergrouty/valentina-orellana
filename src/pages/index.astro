---
export const prerender = false;
import BaseLayout     from '../layouts/BaseLayout.astro';
import Hero           from '../components/sections/Hero.astro';
import TrustBar       from '../components/sections/TrustBar.astro';
import HomeServices   from '../components/sections/HomeServices.astro';
import About          from '../components/sections/About.astro';
import Testimonials   from '../components/sections/Testimonials.astro';
import Contact        from '../components/sections/Contact.astro';
---

<BaseLayout
  title="Inicio"
  description="Ps. Valentina Orellana — Psicóloga clínica para adultos y parejas en Santiago. Terapia presencial y online para bienestar emocional, claridad y relaciones más auténticas."
>
  <Hero />
  <TrustBar />
  <HomeServices />
  <About />
  <Testimonials />
