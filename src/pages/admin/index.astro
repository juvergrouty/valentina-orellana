---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabase } from '../../lib/supabase';
import { SESSION_LABELS } from '../../data/services';

// Reservas del día de hoy
const today = new Date().toISOString().slice(0, 10);

const { data: todayBookings } = await supabase
  .from('bookings')
  .select('*')
  .eq('session_date', today)
  .neq('status', 'cancelled')
  .order('session_time');

// Próximas reservas confirmadas (7 días)
const weekEnd = new Date();
weekEnd.setDate(weekEnd.getDate() + 7);
const weekEndStr = weekEnd.toISOString().slice(0, 10);

const { data: upcoming } = await supabase
  .from('bookings')
  .select('*')
  .eq('status', 'confirmed')
  .gte('session_date', today)
  .lte('session_date', weekEndStr)
  .order('session_date')
  .order('session_time')
  .limit(10);

// Reservas pendientes de pago
const { count: pendingCount } = await supabase
  .from('bookings')
  .select('*', { count: 'exact', head: true })
  .eq('status', 'pending_payment')
  .gte('session_date', today);

// Reservas confirmadas totales del mes
const monthStart = new Date(new Date().getFullYear(), new Date().getMonth(), 1).toISOString().slice(0, 10);
const { count: monthCount } = await supabase
  .from('bookings')
  .select('*', { count: 'exact', head: true })
  .eq('status', 'confirmed')
  .gte('session_date', monthStart);

const formatTime = (t: string) => t.slice(0, 5);
const MONTHS_ES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const formatDate = (iso: string) => {
  const [y, m, d] = iso.split('-');
  return `${parseInt(d)} ${MONTHS_ES[parseInt(m)-1]}`;
};
---

<AdminLayout title="Dashboard" current="/admin">

  <!-- Métricas -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem;">
    <div class="stat-card" style="text-align:center;">
      <p class="stat-label">Sesiones hoy</p>
      <p class="stat-value">{todayBookings?.length ?? 0}</p>
      <p class="stat-sub">{formatDate(today)}</p>
    </div>
    <div class="stat-card" style="text-align:center;">
      <p class="stat-label">Este mes</p>
      <p class="stat-value">{monthCount ?? 0}</p>
      <p class="stat-sub">confirmadas</p>
    </div>
    <div class="stat-card" style="text-align:center;">
      <p class="stat-label">Pago pendiente</p>
      <p class="stat-value" style={(pendingCount ?? 0) > 0 ? 'color:var(--gold)' : ''}>{pendingCount ?? 0}</p>
      <p class="stat-sub">reservas</p>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;">

    <!-- Sesiones de hoy -->
    <div class="card">
      <div class="section-header">
        <p class="label">Hoy — {formatDate(today)}</p>
        <a href="/admin/agenda" class="btn btn-outline btn-sm">Ver agenda</a>
      </div>
      {!todayBookings?.length ? (
        <p style="font-size:0.875rem;color:var(--stone);padding:1rem 0;">Sin sesiones para hoy.</p>
      ) : (
        <div style="display:flex;flex-direction:column;gap:0.5rem;">
          {todayBookings.map((b) => (
            <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem;background:var(--sand);border-radius:var(--radius);">
              <div>
                <p style="font-size:0.9rem;font-weight:500;">{b.patient_name}</p>
                <p style="font-size:0.78rem;color:var(--stone);margin-top:0.15rem;">
                  {SESSION_LABELS[b.session_type as keyof typeof SESSION_LABELS] ?? b.session_type}
                </p>
              </div>
              <div style="text-align:right;">
                <p style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:400;">{formatTime(b.session_time)}</p>
                <span class={`badge badge-${b.status === 'confirmed' ? 'confirmed' : 'pending'}`} style="margin-top:0.25rem;">
                  {b.status === 'confirmed' ? 'Confirmada' : 'Por pagar'}
                </span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Próximas sesiones -->
    <div class="card">
      <div class="section-header">
        <p class="label">Próximos 7 días</p>
        <a href="/admin/agenda" class="btn btn-dark btn-sm">+ Nueva reserva</a>
      </div>
      {!upcoming?.length ? (
        <p style="font-size:0.875rem;color:var(--stone);padding:1rem 0;">Sin sesiones próximas confirmadas.</p>
      ) : (
        <table>
          <thead>
            <tr>
              <th>Paciente</th>
              <th>Fecha</th>
              <th>Hora</th>
              <th>Tipo</th>
            </tr>
          </thead>
          <tbody>
            {upcoming.map((b) => (
              <tr>
                <td style="font-weight:500;">{b.patient_name}</td>
                <td>{formatDate(b.session_date)}</td>
                <td style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;">{formatTime(b.session_time)}</td>
                <td style="color:var(--stone);">
                  {b.session_type === 'online' ? 'Ind. Online' :
                   b.session_type === 'presencial' ? 'Ind. Presencial' :
                   b.session_type === 'pareja-online' ? 'Pareja Online' : 'Pareja Presencial'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

  </div>

</AdminLayout>
