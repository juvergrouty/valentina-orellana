---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabase } from '../../lib/supabase';
import { refreshAccessToken } from '../../lib/googleCalendar';

// Leer settings de Google
const { data: rows } = await supabase.from('settings').select('key, value');
const cfg: Record<string, string> = {};
(rows ?? []).forEach(({ key, value }) => { cfg[key] = value; });

const googleConnected = !!cfg['google_refresh_token'];
const calendarId      = cfg['google_calendar_id'] ?? 'primary';
const googleEmail     = cfg['google_user_email'] ?? '';

// Obtener access_token válido
let accessToken = '';
let events: any[] = [];

if (googleConnected) {
  try {
    const expiry = parseInt(cfg['google_token_expiry'] ?? '0');
    if (!cfg['google_access_token'] || Date.now() > expiry - 60_000) {
      const refreshed = await refreshAccessToken(cfg['google_refresh_token']);
      accessToken = refreshed.access_token;
      await supabase.from('settings').upsert(
        { key: 'google_access_token', value: accessToken, updated_at: new Date().toISOString() },
        { onConflict: 'key' }
      );
    } else {
      accessToken = cfg['google_access_token'];
    }

    // Traer eventos de los próximos 30 días
    const now    = new Date().toISOString();
    const future = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString();
    const evRes  = await fetch(
      `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(calendarId)}/events` +
      `?timeMin=${now}&timeMax=${future}&orderBy=startTime&singleEvents=true&maxResults=20`,
      { headers: { Authorization: `Bearer ${accessToken}` } }
    );
    if (evRes.ok) {
      const evData = await evRes.json();
      events = evData.items ?? [];
    }
  } catch (err) {
    console.error('[calendario]', err);
  }
}

function formatEventDate(ev: any) {
  const dt = ev.start?.dateTime ?? ev.start?.date;
  if (!dt) return '';
  const d = new Date(dt);
  return d.toLocaleDateString('es-CL', { weekday: 'short', day: 'numeric', month: 'short' });
}
function formatEventTime(ev: any) {
  if (!ev.start?.dateTime) return 'Todo el día';
  const d = new Date(ev.start.dateTime);
  return d.toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit' });
}
function isFromSystem(ev: any) {
  return ev.description?.includes('Ps. Valentina Orellana');
}

// URL embed del calendario
const embedUrl = googleConnected
  ? `https://calendar.google.com/calendar/embed?src=${encodeURIComponent(googleEmail)}&ctz=America%2FSantiago&hl=es&mode=WEEK&showTitle=0&showNav=1&showDate=1&showPrint=0&showTabs=0&showCalendars=0`
  : '';
---

<AdminLayout title="Calendario Google" current="/admin/calendario">

  {!googleConnected ? (
    <div class="card" style="text-align:center;padding:3rem;max-width:480px;margin:0 auto;">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color:var(--dust);margin:0 auto 1rem;">
        <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
      </svg>
      <p style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;margin-bottom:0.75rem;">Google Calendar no conectado</p>
      <p style="font-size:0.88rem;color:var(--stone);margin-bottom:1.5rem;">
        Conecta tu cuenta de Google en Configuración para ver tu calendario aquí.
      </p>
      <a href="/admin/configuracion" class="btn btn-dark">Ir a Configuración</a>
    </div>
  ) : (
    <div style="display:grid;grid-template-columns:1fr 300px;gap:1.5rem;align-items:start;">

      <!-- Calendario embebido -->
      <div class="card" style="padding:0;overflow:hidden;">
        <iframe
          src={embedUrl}
          style="border:0;width:100%;height:650px;display:block;"
          frameborder="0"
          scrolling="no"
          title="Google Calendar"
        ></iframe>
      </div>

      <!-- Panel lateral: próximos eventos -->
      <div style="display:flex;flex-direction:column;gap:1rem;">

        <!-- Próximos eventos -->
        <div class="card">
          <p class="label" style="margin-bottom:1.25rem;">Próximos 30 días</p>
          {!events.length ? (
            <p style="font-size:0.85rem;color:var(--stone);">Sin eventos próximos.</p>
          ) : (
            <div style="display:flex;flex-direction:column;gap:0.6rem;">
              {events.map(ev => (
                <div id={`ev-${ev.id}`} style={`padding:0.75rem;border-left:3px solid ${isFromSystem(ev) ? 'var(--forest)' : 'var(--gold)'};background:var(--sand);border-radius:0 4px 4px 0;`}>
                  <div style="display:flex;justify-content:space-between;align-items:start;gap:0.5rem;">
                    <div style="flex:1;min-width:0;">
                      <p style="font-size:0.85rem;font-weight:600;line-height:1.3;">{ev.summary ?? 'Sin título'}</p>
                      <p style="font-size:0.75rem;color:var(--stone);margin-top:0.2rem;">
                        {formatEventDate(ev)} · {formatEventTime(ev)}
                      </p>
                    </div>
                    <button
                      type="button"
                      title="Eliminar evento"
                      onclick={`deleteEvent('${ev.id}')`}
                      style="background:none;border:none;cursor:pointer;color:var(--dust);font-size:0.9rem;padding:0.1rem 0.2rem;flex-shrink:0;transition:color .15s;"
                      onmouseover="this.style.color='var(--red)'"
                      onmouseout="this.style.color='var(--dust)'"
                    >✕</button>
                  </div>
                  {isFromSystem(ev) && (
                    <span style="font-size:0.65rem;background:var(--forest);color:white;padding:0.1rem 0.4rem;border-radius:99px;margin-top:0.3rem;display:inline-block;">
                      Sistema
                    </span>
                  )}
                  {ev.hangoutLink && (
                    <a href={ev.hangoutLink} target="_blank"
                       style="font-size:0.72rem;color:var(--forest);display:block;margin-top:0.25rem;text-decoration:none;">
                      📹 Unirse al Meet
                    </a>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Agregar evento rápido -->
        <div class="card">
          <p class="label" style="margin-bottom:1.25rem;">+ Evento rápido</p>
          <form id="quick-event-form" style="display:flex;flex-direction:column;gap:0.85rem;">
            <div>
              <label class="label" style="display:block;margin-bottom:0.3rem;">Título</label>
              <input type="text" id="ev-title" placeholder="Ej: Supervisión clínica" />
            </div>
            <div>
              <label class="label" style="display:block;margin-bottom:0.3rem;">Fecha</label>
              <input type="date" id="ev-date" value={new Date().toISOString().slice(0,10)} />
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
              <div>
                <label class="label" style="display:block;margin-bottom:0.3rem;">Inicio</label>
                <input type="time" id="ev-start" value="09:00" />
              </div>
              <div>
                <label class="label" style="display:block;margin-bottom:0.3rem;">Fin</label>
                <input type="time" id="ev-end" value="10:00" />
              </div>
            </div>
            <button type="submit" class="btn btn-dark" style="width:100%;justify-content:center;">
              Agregar al calendario
            </button>
            <p id="ev-msg" style="display:none;font-size:0.78rem;text-align:center;"></p>
          </form>
        </div>

      </div>
    </div>
  )}

</AdminLayout>

<script define:vars={{ accessToken, calendarId }}>
  // Eliminar evento del calendario
  window.deleteEvent = async function(eventId) {
    if (!confirm('¿Eliminar este evento del calendario?')) return;
    const el = document.getElementById(`ev-${eventId}`);
    if (el) { el.style.opacity = '0.4'; el.style.pointerEvents = 'none'; }
    try {
      const res = await fetch('/api/admin/google/delete-event', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ eventId }),
      });
      if (res.ok) {
        el?.remove();
      } else {
        if (el) { el.style.opacity = '1'; el.style.pointerEvents = 'auto'; }
        alert('Error al eliminar el evento.');
      }
    } catch {
      if (el) { el.style.opacity = '1'; el.style.pointerEvents = 'auto'; }
      alert('Error de conexión.');
    }
  };

  document.getElementById('quick-event-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn  = e.currentTarget.querySelector('button[type=submit]');
    const msg  = document.getElementById('ev-msg');
    const title = document.getElementById('ev-title').value.trim();
    const date  = document.getElementById('ev-date').value;
    const start = document.getElementById('ev-start').value;
    const end   = document.getElementById('ev-end').value;

    if (!title || !date || !start || !end) return;

    btn.textContent = 'Guardando...';
    btn.disabled    = true;

    try {
      const body = {
        summary: title,
        start: { dateTime: `${date}T${start}:00`, timeZone: 'America/Santiago' },
        end:   { dateTime: `${date}T${end}:00`,   timeZone: 'America/Santiago' },
      };

      const res = await fetch(
        `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(calendarId)}/events`,
        {
          method:  'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body:    JSON.stringify(body),
        }
      );

      if (res.ok) {
        msg.textContent = '✓ Evento agregado. Recarga para verlo.';
        msg.style.color = 'var(--green)';
        msg.style.display = 'block';
        document.getElementById('ev-title').value = '';
      } else {
        throw new Error(await res.text());
      }
    } catch (err) {
      msg.textContent = 'Error al crear el evento.';
      msg.style.color = 'var(--red)';
      msg.style.display = 'block';
    } finally {
      btn.textContent = 'Agregar al calendario';
      btn.disabled    = false;
    }
  });
</script>
