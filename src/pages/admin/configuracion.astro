---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Cargar settings actuales
const { data: rows } = await supabase.from('settings').select('key, value');
const settings: Record<string, string> = {};
(rows ?? []).forEach(({ key, value }) => { settings[key] = value; });

const manualEnabled     = settings['manual_payment_enabled'] !== 'false';
const flowEnabled       = settings['flow_enabled'] !== 'false';
const flowEnv           = settings['flow_env'] ?? 'sandbox'; // default sandbox si no hay fila
const notificationEmail = settings['notification_email'] ?? 'juver@grouty.cl';
const emailFrom         = settings['email_from'] ?? '';
// Google Calendar
const googleEmail    = settings['google_user_email'] ?? null;
const googleName     = settings['google_user_name'] ?? null;
const googleCalName  = settings['google_calendar_name'] ?? null;
const googleConnected = !!googleEmail;

const googleStatus = Astro.url.searchParams.get('google');
const saved = Astro.url.searchParams.get('saved') === '1';
---

<AdminLayout title="Configuración" current="/admin/configuracion">

  {saved && <div class="alert-success">✓ Configuración guardada correctamente.</div>}
  {googleStatus === 'connected'    && <div class="alert-success">✓ Google Calendar conectado correctamente.</div>}
  {googleStatus === 'disconnected' && <div class="alert-success">Google Calendar desconectado.</div>}
  {googleStatus === 'error'        && <div class="alert-error">Error al conectar con Google. Intenta nuevamente.</div>}

  <form method="POST" action="/api/admin/settings" style="display:flex;flex-direction:column;gap:1.5rem;max-width:520px;">
    <input type="hidden" name="redirect" value="/admin/configuracion?saved=1" />

    <!-- Pagos -->
    <div class="card">
      <p class="label" style="margin-bottom:1.25rem;">Métodos de pago</p>

      <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 0;border-bottom:1px solid var(--warm);">
        <div>
          <p style="font-size:0.85rem;font-weight:500;">Pago en consulta</p>
          <p style="font-size:0.72rem;color:var(--stone);margin-top:0.2rem;">
            Permite a los clientes reservar sin pagar online. La reserva queda confirmada directamente.
          </p>
        </div>
        <label style="position:relative;display:inline-block;width:40px;height:22px;flex-shrink:0;margin-left:1rem;">
          <input
            type="checkbox"
            name="manual_payment_enabled"
            value="true"
            checked={manualEnabled}
            style="opacity:0;width:0;height:0;"
            id="toggle-manual"
          />
          <span id="toggle-track" style={`position:absolute;inset:0;border-radius:22px;cursor:pointer;transition:background 0.2s;background:${manualEnabled ? '#576352' : '#DDD8CF'};`}></span>
          <span id="toggle-thumb" style={`position:absolute;top:3px;width:16px;height:16px;border-radius:50%;background:white;transition:left 0.2s;left:${manualEnabled ? '21px' : '3px'};`}></span>
        </label>
      </div>

      <!-- Flow toggle -->
      <div style="padding:0.75rem 0;border-bottom:1px solid var(--warm);">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
          <div>
            <p style="font-size:0.95rem;font-weight:500;">Flow — pago online</p>
            <p style="font-size:0.8rem;color:var(--stone);margin-top:0.2rem;">Webpay, tarjeta de crédito/débito, MACH.</p>
          </div>
          <label style="position:relative;display:inline-block;width:40px;height:22px;flex-shrink:0;margin-left:1rem;">
            <input
              type="checkbox"
              name="flow_enabled"
              value="true"
              checked={flowEnabled}
              style="opacity:0;width:0;height:0;"
              id="toggle-flow"
            />
            <span id="toggle-flow-track" style={`position:absolute;inset:0;border-radius:22px;cursor:pointer;transition:background 0.2s;background:${flowEnabled ? '#576352' : '#DDD8CF'};`}></span>
            <span id="toggle-flow-thumb" style={`position:absolute;top:3px;width:16px;height:16px;border-radius:50%;background:white;transition:left 0.2s;left:${flowEnabled ? '21px' : '3px'};`}></span>
          </label>
        </div>

        <!-- Entorno Flow -->
        <div id="flow-env-section" style={`${!flowEnabled ? 'opacity:0.4;pointer-events:none;' : ''}`}>
          <p class="label" style="margin-bottom:0.6rem;">Entorno de pago</p>
          <div style="display:flex;gap:0.75rem;">
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;padding:0.6rem 1rem;border:2px solid ${flowEnv === 'sandbox' ? 'var(--forest)' : 'var(--dust)'};border-radius:var(--radius);flex:1;background:${flowEnv === 'sandbox' ? '#f0fdf4' : 'white'};" id="label-sandbox">
              <input type="radio" name="flow_env" value="sandbox" checked={flowEnv === 'sandbox'}
                style="width:auto;accent-color:var(--forest);" id="radio-sandbox" />
              <div>
                <p style="font-size:0.85rem;font-weight:600;">Sandbox</p>
                <p style="font-size:0.72rem;color:var(--stone);">sandbox.flow.cl — pruebas</p>
              </div>
            </label>
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;padding:0.6rem 1rem;border:2px solid ${flowEnv === 'production' ? 'var(--forest)' : 'var(--dust)'};border-radius:var(--radius);flex:1;background:${flowEnv === 'production' ? '#f0fdf4' : 'white'};" id="label-production">
              <input type="radio" name="flow_env" value="production" checked={flowEnv === 'production'}
                style="width:auto;accent-color:var(--forest);" id="radio-production" />
              <div>
                <p style="font-size:0.85rem;font-weight:600;">Producción</p>
                <p style="font-size:0.72rem;color:var(--stone);">www.flow.cl — cobros reales</p>
              </div>
            </label>
          </div>
          <p style="font-size:0.8rem;color:var(--stone);margin-top:0.6rem;">
            URL activa: <code style="background:var(--warm);padding:0.1rem 0.4rem;border-radius:3px;font-size:0.75rem;" id="flow-url-preview">
              {flowEnv === 'production' ? 'https://www.flow.cl/api' : 'https://sandbox.flow.cl/api'}
            </code>
          </p>
        </div>
      </div>
    </div>

    <!-- Notificaciones -->
    <div class="card">
      <p class="label" style="margin-bottom:1.25rem;">Notificaciones por email</p>

      <div style="margin-bottom:1rem;">
        <label class="label" style="margin-bottom:0.4rem;display:block;">Email de notificaciones (admin)</label>
        <input
          type="email"
          name="notification_email"
          value={notificationEmail}
          placeholder="tu@correo.cl"
          required
        />
        <p style="font-size:0.7rem;color:var(--stone);margin-top:0.4rem;">
          Recibirás un aviso cada vez que se haga una nueva reserva.
        </p>
      </div>

      <div style="margin-bottom:0.5rem;">
        <label class="label" style="margin-bottom:0.4rem;display:block;">Email remitente (opcional)</label>
        <input
          type="email"
          name="email_from"
          value={emailFrom}
          placeholder="no-reply@psicologavalentinaorellana.com"
        />
        <p style="font-size:0.7rem;color:var(--stone);margin-top:0.4rem;">
          Requiere dominio verificado en Resend. Si está vacío se usa el remitente de prueba.
        </p>
      </div>
    </div>

    <!-- Google Calendar -->
    <div class="card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          <p class="label" style="margin:0;">Google Calendar</p>
        </div>
        {googleConnected
          ? <span style="font-size:0.72rem;background:#f0fdf4;color:var(--green);border:1px solid #86efac;padding:0.2rem 0.6rem;border-radius:99px;font-weight:600;">● Conectado</span>
          : <span style="font-size:0.72rem;background:var(--warm);color:var(--stone);border:1px solid var(--dust);padding:0.2rem 0.6rem;border-radius:99px;">○ No conectado</span>
        }
      </div>

      {googleConnected ? (
        <div>
          <div style="background:var(--sand);padding:1rem;border-radius:var(--radius);margin-bottom:1rem;">
            <p style="font-size:0.85rem;font-weight:600;color:var(--ink);">{googleName}</p>
            <p style="font-size:0.78rem;color:var(--stone);">{googleEmail}</p>
            <p style="font-size:0.75rem;color:var(--stone);margin-top:0.25rem;">📅 Calendario: {googleCalName}</p>
          </div>
          <p style="font-size:0.82rem;color:var(--stone);margin-bottom:1rem;line-height:1.5;">
            Al confirmar una sesión se crea automáticamente un evento en Google Calendar.
            Las sesiones online incluyen un link de Google Meet.
          </p>
          <button type="button" id="btn-google-disconnect" class="btn btn-danger btn-sm">
            Desconectar cuenta
          </button>
        </div>
      ) : (
        <div>
          <p style="font-size:0.85rem;color:var(--stone);margin-bottom:1.25rem;line-height:1.6;">
            Conecta tu cuenta de Google para que cada sesión confirmada se agregue automáticamente
            a tu Google Calendar. Las sesiones online generan un link de Google Meet.
          </p>
          <a href="/api/admin/google/auth" class="btn btn-dark">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Conectar Google Calendar
          </a>
          <p style="font-size:0.75rem;color:var(--stone);margin-top:0.75rem;">
            Requiere <code style="background:var(--warm);padding:0.1rem 0.3rem;border-radius:3px;">GOOGLE_CLIENT_ID</code>,
            <code style="background:var(--warm);padding:0.1rem 0.3rem;border-radius:3px;">GOOGLE_CLIENT_SECRET</code> y
            <code style="background:var(--warm);padding:0.1rem 0.3rem;border-radius:3px;">GOOGLE_REDIRECT_URI</code> en Vercel.
          </p>
        </div>
      )}
    </div>

    <!-- reCAPTCHA -->
    <div class="card">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;">
        <p class="label" style="margin:0;">Google reCAPTCHA</p>
        <span style="font-size:0.65rem;background:var(--warm);color:var(--stone);padding:0.2rem 0.6rem;border-radius:99px;letter-spacing:0.06em;text-transform:uppercase;">Próximamente</span>
      </div>
      <p style="font-size:0.85rem;color:var(--stone);margin-bottom:1.25rem;line-height:1.6;">
        Cuando migres a producción, activa reCAPTCHA v3 para proteger el formulario de agenda
        contra bots. Obtén las claves en
        <a href="https://www.google.com/recaptcha/admin" target="_blank" style="color:var(--forest);">google.com/recaptcha</a>.
      </p>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div>
          <label class="label" style="margin-bottom:0.4rem;display:block;">Site Key (pública)</label>
          <input type="text" name="recaptcha_site_key" value={settings['recaptcha_site_key'] ?? ''} placeholder="6Lc..." />
        </div>
        <div>
          <label class="label" style="margin-bottom:0.4rem;display:block;">Secret Key (privada)</label>
          <input type="password" name="recaptcha_secret_key" value={settings['recaptcha_secret_key'] ?? ''} placeholder="6Lc..." />
        </div>
      </div>
    </div>

    <!-- Resend API Key -->
    <div class="card">
      <p class="label" style="margin-bottom:1.25rem;">Clave API de Resend (email)</p>
      <p style="font-size:0.85rem;color:var(--stone);margin-bottom:1rem;line-height:1.6;">
        Se configura en <strong>Vercel → Settings → Environment Variables</strong>.
        Obtén la key en <a href="https://resend.com" target="_blank" style="color:var(--forest);">resend.com</a> (plan gratuito: 3.000 emails/mes).
      </p>
      <div style="background:var(--sand);padding:0.75rem 1rem;font-size:0.8rem;font-family:monospace;color:var(--stone);border-radius:var(--radius);">
        RESEND_API_KEY = re_xxxxxxxxxxxxxxxx
      </div>
    </div>

    <button type="submit" class="btn btn-dark btn-lg" style="width:100%;justify-content:center;">
      Guardar configuración
    </button>
  </form>

</AdminLayout>

<script>
  // Toggle Flow
  const flowChk   = document.getElementById('toggle-flow');
  const flowTrack = document.getElementById('toggle-flow-track');
  const flowThumb = document.getElementById('toggle-flow-thumb');
  const flowEnvSection = document.getElementById('flow-env-section');
  const flowUrlPreview = document.getElementById('flow-url-preview');

  function updateFlowToggle() {
    const on = (flowChk as HTMLInputElement | null)?.checked;
    if (flowTrack) flowTrack.style.background = on ? '#576352' : '#DDD8CF';
    if (flowThumb) flowThumb.style.left = on ? '21px' : '3px';
    if (flowEnvSection) {
      flowEnvSection.style.opacity = on ? '1' : '0.4';
      flowEnvSection.style.pointerEvents = on ? 'auto' : 'none';
    }
  }
  // El <label> padre activa el checkbox — solo escuchar change para actualizar visual
  flowChk?.addEventListener('change', updateFlowToggle);

  // Radio entorno Flow — actualizar estilos y URL preview
  document.querySelectorAll('input[name="flow_env"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const isProd = document.getElementById('radio-production')?.checked;
      const sandbox    = document.getElementById('label-sandbox');
      const production = document.getElementById('label-production');
      if (sandbox) {
        sandbox.style.borderColor = !isProd ? 'var(--forest)' : 'var(--dust)';
        sandbox.style.background  = !isProd ? '#f0fdf4' : 'white';
      }
      if (production) {
        production.style.borderColor = isProd ? 'var(--forest)' : 'var(--dust)';
        production.style.background  = isProd ? '#f0fdf4' : 'white';
      }
      if (flowUrlPreview) {
        flowUrlPreview.textContent = isProd
          ? 'https://www.flow.cl/api'
          : 'https://sandbox.flow.cl/api';
      }
    });
  });

  // Desconectar Google Calendar sin form anidado
  document.getElementById('btn-google-disconnect')?.addEventListener('click', async () => {
    if (!confirm('¿Desconectar Google Calendar?')) return;
    const res = await fetch('/api/admin/google/disconnect', { method: 'POST' });
    if (res.ok || res.redirected) {
      window.location.href = '/admin/configuracion?google=disconnected';
    } else {
      alert('Error al desconectar. Intenta nuevamente.');
    }
  });

  const checkbox = document.getElementById('toggle-manual') as HTMLInputElement | null;
  const track    = document.getElementById('toggle-track') as HTMLElement | null;
  const thumb    = document.getElementById('toggle-thumb') as HTMLElement | null;

  // El <label> padre ya activa el checkbox al hacer clic — solo escuchar change para actualizar visual
  checkbox?.addEventListener('change', () => {
    const on = (checkbox as HTMLInputElement).checked;
    if (track) track.style.background = on ? '#576352' : '#DDD8CF';
    if (thumb) thumb.style.left = on ? '21px' : '3px';
  });
</script>
