---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabase } from '../../lib/supabase';
import { pricingPlans, SESSION_LABELS } from '../../data/services';

// Mes actual o el que viene por query param
const qYear  = Astro.url.searchParams.get('year');
const qMonth = Astro.url.searchParams.get('month');
const now    = new Date();
const year   = qYear  ? parseInt(qYear)  : now.getFullYear();
const month  = qMonth ? parseInt(qMonth) : now.getMonth() + 1; // 1-12

const monthStart = `${year}-${String(month).padStart(2,'0')}-01`;
const lastDay    = new Date(year, month, 0).getDate();
const monthEnd   = `${year}-${String(month).padStart(2,'0')}-${lastDay}`;

// Reservas del mes (no canceladas)
const { data: bookings } = await supabase
  .from('bookings')
  .select('*')
  .gte('session_date', monthStart)
  .lte('session_date', monthEnd)
  .neq('status', 'cancelled')
  .order('session_date')
  .order('session_time');

// Fechas bloqueadas del mes
const { data: blocked } = await supabase
  .from('blocked_dates')
  .select('date, reason')
  .gte('date', monthStart)
  .lte('date', monthEnd);

// Día seleccionado (por query param o hoy si es este mes)
const qDate     = Astro.url.searchParams.get('date');
const todayIso  = now.toISOString().slice(0, 10);
const isThisMonth = year === now.getFullYear() && month === (now.getMonth() + 1);
const selectedDate = qDate ?? (isThisMonth ? todayIso : monthStart);

// Reservas del día seleccionado (incluyendo canceladas)
const { data: dayBookings } = await supabase
  .from('bookings')
  .select('*')
  .eq('session_date', selectedDate)
  .order('session_time');

// Slots disponibles para ese día (para la reserva manual)
const dayOfWeek = new Date(selectedDate + 'T00:00:00').getDay();
const { data: slots } = await supabase
  .from('availability_slots')
  .select('start_time')
  .eq('day_of_week', dayOfWeek)
  .eq('active', true)
  .order('start_time');

const bookedTimes = new Set(
  (dayBookings ?? []).filter(b => b.status !== 'cancelled').map(b => b.session_time.slice(0,5))
);
const availableSlots = (slots ?? [])
  .map(s => s.start_time.slice(0,5))
  .filter(t => !bookedTimes.has(t));

// Helpers
const bookingsByDate = new Map<string, typeof bookings>();
(bookings ?? []).forEach(b => {
  if (!bookingsByDate.has(b.session_date)) bookingsByDate.set(b.session_date, []);
  bookingsByDate.get(b.session_date)!.push(b);
});
const blockedSet = new Set((blocked ?? []).map(b => b.date));

const MONTHS_ES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
const DAYS_ES   = ['Do','Lu','Ma','Mi','Ju','Vi','Sá'];
const firstDayOfWeek = new Date(year, month - 1, 1).getDay();

const formatCLP = (n: number) =>
  new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);

const prevMonth = month === 1 ? `?year=${year-1}&month=12` : `?year=${year}&month=${month-1}`;
const nextMonth = month === 12 ? `?year=${year+1}&month=1` : `?year=${year}&month=${month+1}`;
---

<AdminLayout title="Agenda" current="/admin/agenda">

  <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;align-items:start;">

    <!-- Calendario -->
    <div class="card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
        <a href={prevMonth} class="btn btn-outline btn-sm">‹</a>
        <p style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:400;">
          {MONTHS_ES[month-1]} {year}
        </p>
        <a href={nextMonth} class="btn btn-outline btn-sm">›</a>
      </div>

      <!-- Cabecera días -->
      <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:4px;">
        {DAYS_ES.map(d => (
          <div style="text-align:center;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--stone);padding:0.4rem 0;">
            {d}
          </div>
        ))}
      </div>

      <!-- Días -->
      <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;">
        {Array.from({ length: firstDayOfWeek }, (_, i) => (
          <div key={`empty-${i}`}></div>
        ))}
        {Array.from({ length: lastDay }, (_, i) => {
          const d   = i + 1;
          const iso = `${year}-${String(month).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
          const dayBks  = bookingsByDate.get(iso) ?? [];
          const isBlocked  = blockedSet.has(iso);
          const isPast     = iso < todayIso;
          const isSelected = iso === selectedDate;
          const isToday    = iso === todayIso;

          const bg = isSelected ? 'var(--ink)' : isBlocked ? 'var(--warm)' : 'transparent';
          const color = isSelected ? 'white' : isPast ? 'var(--dust)' : 'var(--ink)';
          const cursor = isBlocked ? 'default' : 'pointer';

          return (
            <a
              href={`?year=${year}&month=${month}&date=${iso}`}
              style={`display:flex;flex-direction:column;align-items:center;padding:0.5rem 0.25rem;background:${bg};color:${color};text-decoration:none;cursor:${cursor};border:${isToday && !isSelected ? '1px solid var(--dust)' : '1px solid transparent'};`}
            >
              <span style="font-size:0.85rem;">{d}</span>
              {dayBks.length > 0 && (
                <span style={`font-size:0.55rem;letter-spacing:0.08em;margin-top:2px;color:${isSelected ? 'rgba(255,255,255,0.7)' : 'var(--gold)'}`}>
                  {dayBks.length}
                </span>
              )}
              {isBlocked && (
                <span style={`font-size:0.5rem;color:${isSelected ? 'rgba(255,255,255,0.5)' : 'var(--stone)'};margin-top:2px;`}>✕</span>
              )}
            </a>
          );
        })}
      </div>

      <!-- Leyenda -->
      <div style="display:flex;gap:1.5rem;margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--warm);">
        <div style="display:flex;align-items:center;gap:0.4rem;">
          <span style="font-size:0.65rem;color:var(--gold);font-weight:600;">3</span>
          <span style="font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--stone);">Sesiones</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.4rem;">
          <span style="font-size:0.65rem;color:var(--stone);">✕</span>
          <span style="font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--stone);">Bloqueado</span>
        </div>
        <div style="margin-left:auto;">
          <a href="/admin/bloqueos" class="btn btn-outline btn-sm">Gestionar bloqueos</a>
        </div>
      </div>
    </div>

    <!-- Panel derecho: detalle del día -->
    <div style="display:flex;flex-direction:column;gap:1rem;">

      <!-- Reservas del día -->
      <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
          <p class="label">
            {new Date(selectedDate + 'T00:00:00').toLocaleDateString('es-CL', { weekday:'long', day:'numeric', month:'long' })}
          </p>
          {blockedSet.has(selectedDate) && (
            <span class="badge badge-cancelled">Bloqueado</span>
          )}
        </div>

        {!dayBookings?.length ? (
          <p style="font-size:0.8rem;color:var(--stone);">Sin reservas para este día.</p>
        ) : (
          <div style="display:flex;flex-direction:column;gap:0.6rem;">
            {dayBookings.map((b) => (
              <div style={`padding:0.75rem;border:1px solid var(--warm);background:${b.status === 'cancelled' ? 'var(--sand)' : 'white'};`}>
                <div style="display:flex;justify-content:space-between;align-items:start;gap:0.5rem;">
                  <div style="flex:1;min-width:0;">
                    <p style={`font-size:0.85rem;font-weight:500;${b.status === 'cancelled' ? 'text-decoration:line-through;color:var(--stone);' : ''}`}>
                      {b.patient_name}
                    </p>
                    <p style="font-size:0.7rem;color:var(--stone);margin-top:0.15rem;">
                      {SESSION_LABELS[b.session_type as keyof typeof SESSION_LABELS] ?? b.session_type}
                    </p>
                    <p style="font-size:0.7rem;color:var(--stone);">{b.patient_phone}</p>
                  </div>
                  <div style="text-align:right;flex-shrink:0;">
                    <p style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;">{b.session_time.slice(0,5)}</p>
                    <span class={`badge badge-${b.status === 'confirmed' ? 'confirmed' : b.status === 'cancelled' ? 'cancelled' : 'pending'}`} style="margin-top:0.25rem;display:inline-block;">
                      {b.status === 'confirmed' ? 'Confirmada' : b.status === 'cancelled' ? 'Cancelada' : 'Por pagar'}
                    </span>
                  </div>
                </div>
                {b.status !== 'cancelled' && (
                  <div style="display:flex;gap:0.5rem;margin-top:0.6rem;">
                    {b.status === 'pending_payment' && (
                      <form method="POST" action="/api/admin/bookings">
                        <input type="hidden" name="action" value="confirm" />
                        <input type="hidden" name="id" value={b.id} />
                        <input type="hidden" name="redirect" value={`/admin/agenda?year=${year}&month=${month}&date=${selectedDate}`} />
                        <button type="submit" class="btn btn-outline btn-sm">✓ Confirmar</button>
                      </form>
                    )}
                    <form method="POST" action="/api/admin/bookings">
                      <input type="hidden" name="action" value="cancel" />
                      <input type="hidden" name="id" value={b.id} />
                      <input type="hidden" name="redirect" value={`/admin/agenda?year=${year}&month=${month}&date=${selectedDate}`} />
                      <button type="submit" class="btn btn-danger btn-sm">Cancelar</button>
                    </form>
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Botón nueva reserva -->
      <button id="open-modal" class="btn btn-dark" style="width:100%;justify-content:center;padding:0.7rem;">
        + Nueva reserva manual
      </button>

    </div>
  </div>

</AdminLayout>

<!-- ── Modal nueva reserva ──────────────────────────────────────────────────── -->
<div id="modal-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:100;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:white;width:100%;max-width:440px;max-height:90vh;overflow-y:auto;padding:2rem;position:relative;">

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
      <p class="label">Nueva reserva manual</p>
      <button id="close-modal" style="background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--stone);line-height:1;">✕</button>
    </div>

    <form method="POST" action="/api/admin/bookings" style="display:flex;flex-direction:column;gap:1rem;">
      <input type="hidden" name="action" value="create" />
      <input type="hidden" name="redirect" value={`/admin/agenda?year=${year}&month=${month}&date=${selectedDate}`} />

      <div>
        <label class="label" style="margin-bottom:0.3rem;display:block;">Fecha</label>
        <input type="date" name="session_date" value={selectedDate} required />
      </div>

      <div>
        <label class="label" style="margin-bottom:0.3rem;display:block;">Tipo de sesión</label>
        <select name="session_type" required>
          {pricingPlans.map(p => (
            <option value={p.id}>{p.title} — {new Intl.NumberFormat('es-CL',{style:'currency',currency:'CLP',maximumFractionDigits:0}).format(p.price)}</option>
          ))}
        </select>
      </div>

      <div>
        <label class="label" style="margin-bottom:0.3rem;display:block;">Hora</label>
        <select name="session_time" id="modal-time-select" required>
          {availableSlots.length === 0
            ? <option value="">Sin slots disponibles</option>
            : availableSlots.map(t => <option value={t}>{t}</option>)
          }
          <option value="custom">— Horario personalizado</option>
        </select>
      </div>

      <div id="custom-time-wrap" style="display:none;">
        <label class="label" style="margin-bottom:0.3rem;display:block;">Horario personalizado</label>
        <input type="time" name="custom_time" step="300" />
      </div>

      <div>
        <label class="label" style="margin-bottom:0.3rem;display:block;">Nombre paciente</label>
        <input type="text" name="patient_name" required placeholder="Nombre completo" />
      </div>
      <div>
        <label class="label" style="margin-bottom:0.3rem;display:block;">Teléfono</label>
        <input type="tel" name="patient_phone" required placeholder="+56 9 XXXX XXXX" />
      </div>
      <div>
        <label class="label" style="margin-bottom:0.3rem;display:block;">Correo</label>
        <input type="email" name="patient_email" required placeholder="correo@ejemplo.cl" />
      </div>
      <div>
        <label class="label" style="margin-bottom:0.3rem;display:block;">Notas (opcional)</label>
        <textarea name="notes" rows="2" placeholder="Observaciones..."></textarea>
      </div>

      <button type="submit" class="btn btn-dark" style="width:100%;justify-content:center;margin-top:0.5rem;">
        Crear reserva confirmada
      </button>
    </form>
  </div>
</div>

<script>
  // Modal
  const overlay   = document.getElementById('modal-overlay');
  const openBtn   = document.getElementById('open-modal');
  const closeBtn  = document.getElementById('close-modal');

  openBtn?.addEventListener('click', () => {
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  });
  const closeModal = () => {
    overlay.style.display = 'none';
    document.body.style.overflow = '';
  };
  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });

  // Horario personalizado
  const select = document.getElementById('modal-time-select');
  const wrap   = document.getElementById('custom-time-wrap');
  select?.addEventListener('change', () => {
    wrap.style.display = select.value === 'custom' ? 'block' : 'none';
  });
</script>
