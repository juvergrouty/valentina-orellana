<script>
// ── Constants ─────────────────────────────────────────────────────────────────
const MONTHS_LONG = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const DAYS_LONG   = ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];
const DAYS_CAP    = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];

function formatCLP(n) {
  return new Intl.NumberFormat('es-CL',{style:'currency',currency:'CLP',maximumFractionDigits:0}).format(n ?? 0);
}
function addMins(t, mins) {
  const [h, m] = t.split(':').map(Number);
  const tot = h * 60 + m + mins;
  return `${String(Math.floor(tot/60)%24).padStart(2,'0')}:${String(tot%60).padStart(2,'0')}`;
}
function isoToLong(iso) {
  const [y, mo, d] = iso.split('-').map(Number);
  const date = new Date(y, mo - 1, d);
  return `${DAYS_CAP[date.getDay()]}, ${d} de ${MONTHS_LONG[mo-1]} de ${y}`;
}
function isoToLabel(iso) {
  // "Viernes 12 de junio del 2026"
  const [y, mo, d] = iso.split('-').map(Number);
  const date = new Date(y, mo - 1, d);
  return `${DAYS_CAP[date.getDay()]} ${d} de ${MONTHS_LONG[mo-1]} de ${y}`;
}

// ── Now line ──────────────────────────────────────────────────────────────────
const nowLine = document.getElementById('now-line');
function updateNowLine() {
  if (!nowLine) return;
  const n = new Date();
  const mins = (n.getHours() - 6) * 60 + n.getMinutes();
  if (mins < 0 || mins > 1020) { nowLine.style.display = 'none'; return; }
  nowLine.style.display = '';
  nowLine.style.top = mins + 'px';
}
updateNowLine();
setInterval(updateNowLine, 60_000);

// Scroll to current hour
const calScroll = document.getElementById('cal-scroll');
if (calScroll) calScroll.scrollTop = Math.max(0, (new Date().getHours() - 8) * 60);

// ── Panel helpers ─────────────────────────────────────────────────────────────
const bookingPanel = document.getElementById('booking-panel');
const sessionPanel = document.getElementById('session-panel');

function openBookingPanel(date, time) {
  sessionPanel.classList.remove('open');
  bookingPanel.classList.add('open');
}
function openSessionPanel() {
  bookingPanel.classList.remove('open');
  sessionPanel.classList.add('open');
}
function closeAll() {
  bookingPanel.classList.remove('open');
  sessionPanel.classList.remove('open');
  if (typeof clearDragSel === 'function') clearDragSel();
}

document.getElementById('bp-close')?.addEventListener('click', closeAll);
document.getElementById('sp-close')?.addEventListener('click', closeAll);

document.addEventListener('click', e => {
  if (bookingPanel.classList.contains('open') || sessionPanel.classList.contains('open')) {
    if (!bookingPanel.contains(e.target) && !sessionPanel.contains(e.target) && !e.target.closest('.cal-event') && !e.target.closest('.cal-col') && !e.target.closest('#open-new-btn')) {
      closeAll();
    }
  }
});

// ── Click-to-book + drag-to-block ────────────────────────────────────────────
const calGrid    = document.getElementById('cal-grid');
const calScrollEl = document.getElementById('cal-scroll');

function getTimeFromClientY(clientY) {
  const gridRect = calGrid.getBoundingClientRect();
  const relY     = Math.max(0, Math.min(1019, clientY - gridRect.top));
  const snapped  = Math.floor(relY / 15) * 15;
  const h        = 6 + Math.floor(snapped / 60);
  const m        = snapped % 60;
  return { time: `${String(Math.min(h,22)).padStart(2,'0')}:${String(m).padStart(2,'0')}`, snapped };
}

let dragState = null;
const allCols = Array.from(document.querySelectorAll('.cal-col'));

function clearDragSel() {
  allCols.forEach(c => {
    c.classList.remove('drag-sel');
    c.style.removeProperty('--drag-top');
    c.style.removeProperty('--drag-h');
  });
}

// Find column index whose horizontal span contains clientX (geometry — never fails)
function colIndexAtX(clientX) {
  for (let i = 0; i < allCols.length; i++) {
    const r = allCols[i].getBoundingClientRect();
    if (clientX < r.right) return i;
  }
  return allCols.length - 1;
}

function applyDragSel(startIdx, endIdx, fromSnap, toSnap) {
  const lo   = Math.min(startIdx, endIdx), hi = Math.max(startIdx, endIdx);
  const from = Math.min(fromSnap, toSnap);
  const to   = Math.max(fromSnap, toSnap);
  allCols.forEach((c, i) => {
    if (i >= lo && i <= hi) {
      c.classList.add('drag-sel');
      c.style.setProperty('--drag-top', `${from}px`);
      c.style.setProperty('--drag-h',   `${Math.max(15, to - from)}px`);
    } else {
      c.classList.remove('drag-sel');
      c.style.removeProperty('--drag-top');
      c.style.removeProperty('--drag-h');
    }
  });
}

allCols.forEach(col => {
  col.addEventListener('mousedown', e => {
    if (e.target.closest('.cal-event')) return;
    if (e.button !== 0) return;
    e.preventDefault();

    const startIdx = allCols.indexOf(col);
    const { time, snapped } = getTimeFromClientY(e.clientY);
    dragState = {
      startDate: col.dataset.date, startTime: time,
      startX: e.clientX, startY: e.clientY,
      startIdx, startSnap: snapped,
      endIdx: startIdx, endSnap: snapped,
      isDragging: false,
    };

    function onMove(ev) {
      if (!dragState) return;
      const dist = Math.hypot(ev.clientX - dragState.startX, ev.clientY - dragState.startY);
      if (dist > 8 && !dragState.isDragging) {
        dragState.isDragging = true;
        document.body.style.cursor = 'copy';
        calScrollEl.style.overflowY = 'hidden';
      }
      if (!dragState.isDragging) return;
      dragState.endIdx  = colIndexAtX(ev.clientX);
      dragState.endSnap = getTimeFromClientY(ev.clientY).snapped;
      applyDragSel(dragState.startIdx, dragState.endIdx, dragState.startSnap, dragState.endSnap);
    }

    function onUp() {
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup',   onUp);
      document.body.style.cursor  = '';
      calScrollEl.style.overflowY = '';
      if (!dragState) return;
      const state = dragState;
      dragState   = null;

      if (state.isDragging) {
        // Keep highlight visible while the panel is open
        applyDragSel(state.startIdx, state.endIdx, state.startSnap, state.endSnap);

        const lo = Math.min(state.startIdx, state.endIdx);
        const hi = Math.max(state.startIdx, state.endIdx);
        const fromSnap = Math.min(state.startSnap, state.endSnap);
        const toSnap   = Math.max(state.startSnap, state.endSnap);
        const snapToTime = s => {
          const h = 6 + Math.floor(s / 60), m = s % 60;
          return `${String(Math.min(h,23)).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
        };
        const fromDate = allCols[lo].dataset.date;
        const toDate   = allCols[hi].dataset.date;
        const fromTime = snapToTime(fromSnap);
        const toTime   = snapToTime(Math.max(toSnap, fromSnap + 15));
        openBloqueoPanel(fromDate, fromTime, toDate, toTime);
      } else {
        clearDragSel();
        const date = state.startDate;
        const time = state.startTime;
        document.getElementById('bp-date').value = date;
        document.getElementById('bp-time').value = time;
        document.getElementById('bp-date-label').textContent = isoToLabel(date);
        document.getElementById('bp-tab-agenda').classList.add('active');
        document.getElementById('bp-tab-block').classList.remove('active');
        document.getElementById('bp-agenda-body').style.display = '';
        document.getElementById('bp-block-body').style.display  = 'none';
        openBookingPanel(date, time);
      }
    }

    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup',   onUp);
  });
});

// Toolbar "+ Agendar" button
document.getElementById('open-new-btn')?.addEventListener('click', () => {
  const today = new Date().toISOString().split('T')[0];
  const now   = new Date();
