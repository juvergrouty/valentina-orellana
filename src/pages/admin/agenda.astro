---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabase } from '../../lib/supabase';
import { pricingPlans, SESSION_LABELS } from '../../data/services';

const today   = new Date().toISOString().slice(0, 10);
const in30days = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

// Próximas reservas (30 días)
const { data: upcoming } = await supabase
  .from('bookings')
  .select('id, patient_name, session_type, session_date, session_time, status, amount')
  .gte('session_date', today)
  .lte('session_date', in30days)
  .neq('status', 'cancelled')
  .order('session_date')
  .order('session_time')
  .limit(40);

const MONTHS_SHORT = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
function shortDate(iso: string) {
  const [, m, d] = iso.split('-');
  return `${parseInt(d)} ${MONTHS_SHORT[parseInt(m)-1]}`;
}

// Slots para el modal de nueva reserva (día de hoy por defecto)
const dayOfWeek = new Date(today + 'T00:00:00').getDay();
const { data: slots } = await supabase
  .from('availability_slots')
  .select('start_time')
  .eq('day_of_week', dayOfWeek)
  .eq('active', true)
  .order('start_time');
const availableSlots = (slots ?? []).map(s => s.start_time.slice(0, 5));

const formatCLP = (n: number) =>
  new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);

const errorParam = Astro.url.searchParams.get('error');
---

<AdminLayout title="Agenda" current="/admin/agenda">

  {errorParam === 'conflict' && <div class="alert-error">⚠ Ese horario ya está ocupado. Elige otro.</div>}

  <!-- Acciones superiores -->
  <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1.25rem;flex-wrap:wrap;">
    <div style="display:flex;gap:0.5rem;align-items:center;">
      <span style="font-size:0.78rem;color:var(--stone);">Haz clic en un espacio vacío para crear una reserva · Arrastra para reagendar</span>
    </div>
    <div style="display:flex;gap:0.5rem;">
      <a href="/admin/bloqueos" class="btn btn-outline btn-sm">Gestionar bloqueos</a>
      <button id="open-modal" class="btn btn-dark btn-sm">+ Nueva reserva</button>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 280px;gap:1.25rem;align-items:start;">

    <!-- FullCalendar -->
    <div class="card" style="padding:1.25rem;">
      <div style="display:flex;gap:1.25rem;margin-bottom:1rem;font-size:0.75rem;color:var(--stone);flex-wrap:wrap;align-items:center;">
        <span style="display:flex;align-items:center;gap:0.35rem;">
          <span style="width:12px;height:12px;border-radius:2px;background:#22C55E;display:inline-block;"></span> Confirmada
        </span>
        <span style="display:flex;align-items:center;gap:0.35rem;">
          <span style="width:12px;height:12px;border-radius:2px;background:#F97316;display:inline-block;"></span> Pendiente pago
        </span>
        <span style="display:flex;align-items:center;gap:0.35rem;">
          <span style="width:12px;height:12px;border-radius:2px;background:#6B7280;display:inline-block;"></span> Google Calendar
        </span>
      </div>
      <div id="fullcalendar" style="min-height:600px;"></div>
    </div>

    <!-- Lista lateral de próximas reservas -->
    <div style="display:flex;flex-direction:column;gap:0.75rem;position:sticky;top:90px;">
      <div class="card" style="padding:1.25rem;">
        <p class="label" style="margin-bottom:1rem;">Próximas sesiones</p>

        {!upcoming?.length ? (
          <p style="font-size:0.82rem;color:var(--stone);text-align:center;padding:1rem 0;">Sin sesiones próximas</p>
        ) : (
          <div style="display:flex;flex-direction:column;gap:0;">
            {upcoming.map((b, i) => {
              const isConfirmed = b.status === 'confirmed';
              const dotColor    = isConfirmed ? '#22C55E' : '#F97316';
              const labelShort  = { online:'Online', presencial:'Presencial', 'pareja-online':'Par. Online', 'pareja-presencial':'Par. Presencial' }[b.session_type] ?? b.session_type;
              return (
                <div style={`display:flex;align-items:start;gap:0.6rem;padding:0.65rem 0;${i < upcoming.length-1 ? 'border-bottom:1px solid var(--warm);' : ''}`}>
                  <div style={`width:8px;height:8px;border-radius:50%;background:${dotColor};flex-shrink:0;margin-top:5px;`}></div>
                  <div style="flex:1;min-width:0;">
                    <p style="font-size:0.82rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{b.patient_name}</p>
                    <p style="font-size:0.72rem;color:var(--stone);">{shortDate(b.session_date)} · {b.session_time.slice(0,5)}</p>
                    <p style="font-size:0.68rem;color:var(--stone);">{labelShort}</p>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>

      <!-- Stats rápidas -->
      <div class="card" style="padding:1.25rem;">
        <p class="label" style="margin-bottom:0.75rem;">Resumen</p>
        <div style="display:flex;flex-direction:column;gap:0.5rem;">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:0.8rem;color:var(--stone);">Confirmadas</span>
            <span style="font-size:0.9rem;font-weight:700;color:#22C55E;">
              {upcoming?.filter(b => b.status === 'confirmed').length ?? 0}
            </span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:0.8rem;color:var(--stone);">Pendiente pago</span>
            <span style="font-size:0.9rem;font-weight:700;color:#F97316;">
              {upcoming?.filter(b => b.status === 'pending_payment').length ?? 0}
            </span>
          </div>
          <div style="border-top:1px solid var(--warm);padding-top:0.5rem;display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:0.8rem;color:var(--stone);">Total 30 días</span>
            <span style="font-size:0.9rem;font-weight:700;color:var(--ink);">{upcoming?.length ?? 0}</span>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Panel detalle de reserva (popup lateral) -->
  <div id="booking-detail" style="display:none;position:fixed;right:1.5rem;top:90px;width:320px;background:white;border:1px solid var(--dust);border-radius:8px;box-shadow:0 8px 32px rgba(0,0,0,.12);z-index:50;padding:1.5rem;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
      <p class="label" id="detail-label">Detalle</p>
      <button onclick="closeDetail()" style="background:none;border:none;cursor:pointer;font-size:1.2rem;color:var(--stone);">✕</button>
    </div>
    <div id="detail-content"></div>
    <div id="detail-actions" style="display:flex;gap:0.5rem;margin-top:1rem;flex-wrap:wrap;"></div>
  </div>

</AdminLayout>

<!-- Modal nueva reserva -->
<div id="modal-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:100;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:white;width:100%;max-width:440px;max-height:90vh;overflow-y:auto;padding:2rem;border-radius:6px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
      <p class="label" id="modal-title">Nueva reserva manual</p>
      <button id="close-modal" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--stone);">✕</button>
    </div>
    <form method="POST" action="/api/admin/bookings" style="display:flex;flex-direction:column;gap:1rem;">
      <input type="hidden" name="action" value="create" />
      <input type="hidden" name="redirect" value="/admin/agenda" />
      <div>
        <label class="label" style="display:block;margin-bottom:0.3rem;">Fecha</label>
        <input type="date" id="modal-date" name="session_date" value={today} required />
      </div>
      <div>
        <label class="label" style="display:block;margin-bottom:0.3rem;">Tipo de sesión</label>
        <select name="session_type" required>
          {pricingPlans.map(p => (
            <option value={p.id}>{p.title} — {formatCLP(p.price)}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="label" style="display:block;margin-bottom:0.3rem;">Hora</label>
        <select id="modal-time" name="session_time" required>
          {availableSlots.length === 0
            ? <option value="">Sin slots disponibles</option>
            : availableSlots.map(t => <option value={t}>{t}</option>)
          }
          <option value="custom">— Horario personalizado</option>
        </select>
      </div>
      <div id="custom-time-wrap" style="display:none;">
        <label class="label" style="display:block;margin-bottom:0.3rem;">Horario personalizado</label>
        <input type="time" id="modal-custom-time" name="custom_time" step="300" />
      </div>
      <div>
        <label class="label" style="display:block;margin-bottom:0.3rem;">Nombre paciente *</label>
        <input type="text" name="patient_name" required placeholder="Nombre completo" />
      </div>
      <div>
        <label class="label" style="display:block;margin-bottom:0.3rem;">Teléfono *</label>
        <input type="tel" name="patient_phone" required placeholder="+56 9 XXXX XXXX" />
      </div>
      <div>
        <label class="label" style="display:block;margin-bottom:0.3rem;">Correo *</label>
        <input type="email" name="patient_email" required placeholder="correo@ejemplo.cl" />
      </div>
      <div>
        <label class="label" style="display:block;margin-bottom:0.3rem;">Notas (opcional)</label>
        <textarea name="notes" rows="2" placeholder="Observaciones..."></textarea>
      </div>
      <button type="submit" class="btn btn-dark" style="width:100%;justify-content:center;margin-top:0.5rem;">
        Crear reserva confirmada
      </button>
    </form>
  </div>
</div>

<!-- Script: carga FullCalendar y lógica de la agenda -->
<script>
  // ── Helpers ──────────────────────────────────────────────────────────────────
  const overlay  = document.getElementById('modal-overlay');
  const closeBtn = document.getElementById('close-modal');
  const openBtn  = document.getElementById('open-modal');
  const modalDate = document.getElementById('modal-date');
  const modalTime = document.getElementById('modal-time');
  const customWrap = document.getElementById('custom-time-wrap');
  const customTime = document.getElementById('modal-custom-time');

  const openModal = (date, time) => {
    if (date && modalDate) modalDate.value = date;
    if (time && modalTime) {
      const opt = Array.from(modalTime.options).find(o => o.value === time);
      if (opt) { modalTime.value = time; customWrap.style.display = 'none'; }
      else { modalTime.value = 'custom'; customWrap.style.display = 'block'; if (customTime) customTime.value = time; }
    }
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  };
  const closeModal = () => { overlay.style.display = 'none'; document.body.style.overflow = ''; };

  openBtn?.addEventListener('click', () => openModal(null, null));
  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
  modalTime?.addEventListener('change', () => {
    customWrap.style.display = modalTime.value === 'custom' ? 'block' : 'none';
  });

  // ── Panel detalle ──────────────────────────────────────────────────────────
  window.closeDetail = () => { document.getElementById('booking-detail').style.display = 'none'; };

  function showBookingDetail(event) {
    const props = event.extendedProps;
    const panel  = document.getElementById('booking-detail');
    const label  = document.getElementById('detail-label');
    const content = document.getElementById('detail-content');
    const actions = document.getElementById('detail-actions');

    const startTime = event.start ? event.start.toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit' }) : '';
    const date = event.start ? event.start.toLocaleDateString('es-CL', { weekday: 'long', day: 'numeric', month: 'long' }) : '';

    if (props.type === 'gcal') {
      label.textContent = 'Google Calendar';
      content.innerHTML = `
        <p style="font-weight:600;font-size:0.95rem;margin-bottom:0.5rem;">${event.title}</p>
        <p style="font-size:0.82rem;color:var(--stone);">${date}</p>
        <p style="font-size:0.82rem;color:var(--stone);">${startTime}</p>
        ${props.meetLink ? `<a href="${props.meetLink}" target="_blank" style="font-size:0.82rem;color:var(--forest);display:block;margin-top:0.5rem;">📹 Unirse al Meet</a>` : ''}
      `;
      actions.innerHTML = `
        <button onclick="deleteGcalEvent('${props.googleEventId}')" class="btn btn-danger btn-sm">Eliminar evento</button>
      `;
    } else {
      const statusLabel = props.status === 'confirmed' ? 'Confirmada' : 'Pendiente pago';
      const statusColor = props.status === 'confirmed' ? 'var(--green)' : 'var(--gold)';
      label.textContent = 'Reserva';
      content.innerHTML = `
        <p style="font-weight:600;font-size:0.95rem;margin-bottom:0.25rem;">${event.title.split(' · ')[0]}</p>
        <p style="font-size:0.82rem;color:var(--stone);margin-bottom:0.5rem;">${event.title.split(' · ')[1] ?? ''}</p>
        <p style="font-size:0.82rem;color:var(--stone);">${date}</p>
        <p style="font-size:0.82rem;color:var(--stone);">${startTime}</p>
        <p style="font-size:0.8rem;font-weight:600;color:${statusColor};margin-top:0.5rem;">${statusLabel}</p>
      `;
      const bookingId = props.bookingId;
      const dateStr = event.start ? event.start.toISOString().slice(0, 10) : '';
      actions.innerHTML = `
        <form method="POST" action="/api/admin/bookings" style="margin:0;">
          <input type="hidden" name="action" value="confirm" />
          <input type="hidden" name="id" value="${bookingId}" />
          <input type="hidden" name="redirect" value="/admin/agenda" />
          ${props.status === 'pending_payment' ? '<button type="submit" class="btn btn-outline btn-sm">✓ Confirmar</button>' : ''}
        </form>
        <form method="POST" action="/api/admin/bookings" style="margin:0;">
          <input type="hidden" name="action" value="cancel" />
          <input type="hidden" name="id" value="${bookingId}" />
          <input type="hidden" name="redirect" value="/admin/agenda" />
          <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Cancelar esta reserva?')">Cancelar</button>
        </form>
      `;
    }

    panel.style.display = 'block';
  }

  window.deleteGcalEvent = async (eventId) => {
    if (!confirm('¿Eliminar este evento de Google Calendar?')) return;
    const res = await fetch('/api/admin/google/delete-event', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ eventId }),
    });
    if (res.ok) { closeDetail(); calendar?.refetchEvents(); }
    else alert('Error al eliminar.');
  };

  // ── FullCalendar ────────────────────────────────────────────────────────────
  let calendar;

  const fcScript = document.createElement('script');
  fcScript.src = 'https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js';
  fcScript.onload = initCalendar;
  document.head.appendChild(fcScript);

  const fcCss = document.createElement('link');
  fcCss.rel  = 'stylesheet';
  fcCss.href = 'https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css';
  document.head.appendChild(fcCss);

  function initCalendar() {
    const el = document.getElementById('fullcalendar');
    if (!el || !window.FullCalendar) return;

    calendar = new window.FullCalendar.Calendar(el, {
      initialView:   'timeGridWeek',
      locale:        'es',
      firstDay:      1,
      slotMinTime:   '00:00:00',
      slotMaxTime:   '24:00:00',
      slotDuration:  '00:30:00',
      height:        650,
      scrollTime:    '07:00:00', // vista inicial desde las 7am, pero se puede scrollear
      nowIndicator:  true,
      allDaySlot:    true,
      editable:      false,
      selectable:    true,
      headerToolbar: {
        left:   'prev,next today',
        center: 'title',
        right:  'dayGridMonth,timeGridWeek,timeGridDay',
      },
      buttonText: { today: 'Hoy', month: 'Mes', week: 'Semana', day: 'Día' },

      // Fuente de eventos combinada
      events: async (info, success, failure) => {
        try {
          const res  = await fetch(`/api/admin/calendar-events?start=${info.startStr}&end=${info.endStr}`);
          const data = await res.json();
          success(data);
        } catch { failure({}); }
      },

      // Clic en espacio vacío → abrir modal con fecha/hora
      dateClick: (info) => {
        const date = info.dateStr.slice(0, 10);
        const time = info.dateStr.length > 10 ? info.dateStr.slice(11, 16) : null;
        openModal(date, time);
      },

      // Clic en evento → panel de detalle
      eventClick: (info) => {
        info.jsEvent.stopPropagation();
        showBookingDetail(info.event);
      },

      // Estilos visuales
      eventDidMount: (info) => {
        const type = info.event.extendedProps.type;
        if (type === 'gcal') info.el.style.opacity = '0.8';
        if (info.event.extendedProps.meetLink) {
          info.el.setAttribute('title', '📹 Tiene link de Meet');
        }
      },
    });

    calendar.render();
  }

  // Cerrar panel al clic fuera
  document.addEventListener('click', (e) => {
    const panel = document.getElementById('booking-detail');
    if (panel && !panel.contains(e.target) && !e.target.closest('.fc-event')) {
      panel.style.display = 'none';
    }
  });
</script>
