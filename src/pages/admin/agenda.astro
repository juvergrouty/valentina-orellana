// ── Booking panel: service selector → price ──────────────────────────────────
const bpServiceSel = document.getElementById('bp-service-sel');
const bpSessionsSel = document.getElementById('bp-sessions');
const bpPriceValue  = document.getElementById('bp-price-value');
const bpPriceNote   = document.getElementById('bp-price-note');
const bpModalityRow = document.getElementById('bp-modality-row');

function updatePrice() {
  const opt    = bpServiceSel?.selectedOptions[0];
  if (!opt || !opt.value) {
    bpPriceValue.textContent = '—';
    bpPriceNote.textContent  = 'Selecciona un servicio para ver el precio';
    return;
  }
  const modality = opt.dataset.modality;
  let price;
  if (modality === 'ambos') {
    const isOnline = document.getElementById('bp-mod-online')?.checked;
    price = parseInt(isOnline ? (opt.dataset.priceOnline || opt.dataset.price) : (opt.dataset.pricePres || opt.dataset.price));
  } else {
    price = parseInt(opt.dataset.price || '0');
  }
  const count = parseInt(bpSessionsSel?.value || '1');
  bpPriceValue.textContent = formatCLP(price);
  bpPriceNote.textContent  = count > 1
    ? `Precio total del paquete · ${count} sesiones semanales`
    : 'Precio de la sesión';
}

bpServiceSel?.addEventListener('change', () => {
  const opt      = bpServiceSel.selectedOptions[0];
  const modality = opt?.dataset.modality;
  bpModalityRow.style.display = modality === 'ambos' ? 'flex' : 'none';
  updatePrice();
});
bpSessionsSel?.addEventListener('change', updatePrice);
document.querySelectorAll('input[name="modality_choice"]').forEach(r => r.addEventListener('change', updatePrice));

// ── Booking panel: tabs ───────────────────────────────────────────────────────
document.getElementById('bp-tab-agenda')?.addEventListener('click', () => {
  document.getElementById('bp-tab-agenda').classList.add('active');
  document.getElementById('bp-tab-block').classList.remove('active');
  document.getElementById('bp-agenda-body').style.display = '';
  document.getElementById('bp-block-body').style.display  = 'none';
});
document.getElementById('bp-tab-block')?.addEventListener('click', () => {
  document.getElementById('bp-tab-block').classList.add('active');
  document.getElementById('bp-tab-agenda').classList.remove('active');
  document.getElementById('bp-block-body').style.display  = '';
  document.getElementById('bp-agenda-body').style.display = 'none';
});

// ── openBloqueoPanel ──────────────────────────────────────────────────────────
function openBloqueoPanel(fromDate, fromTime, toDate, toTime) {
  document.getElementById('bp-tab-block').classList.add('active');
  document.getElementById('bp-tab-agenda').classList.remove('active');
  document.getElementById('bp-block-body').style.display  = '';
  document.getElementById('bp-agenda-body').style.display = 'none';

  document.getElementById('bp-blk-dfrom').value = fromDate;
  document.getElementById('bp-blk-dto').value   = toDate;
  document.getElementById('bp-blk-tfrom').value = fromTime;
  document.getElementById('bp-blk-tto').value   = toTime;
  document.getElementById('bp-blk-label').value = '';
  document.getElementById('bp-allday').checked  = false;
  // Ensure time fields visible
  document.getElementById('bp-blk-tfrom-wrap').style.visibility = '';
  document.getElementById('bp-blk-tto-wrap').style.visibility   = '';

  const label = fromDate === toDate ? isoToLabel(fromDate) : `${isoToLabel(fromDate)} – ${isoToLabel(toDate)}`;
  document.getElementById('bp-date-label').textContent = label;

  sessionPanel.classList.remove('open');
  bookingPanel.classList.add('open');
}

// ── Bloquear hora: all-day toggle ─────────────────────────────────────────────
document.getElementById('bp-allday')?.addEventListener('change', function() {
  const hide = this.checked;
  document.getElementById('bp-blk-tfrom-wrap').style.visibility = hide ? 'hidden' : '';
  document.getElementById('bp-blk-tto-wrap').style.visibility   = hide ? 'hidden' : '';
  document.getElementById('bp-blk-time-hdr').style.visibility   = hide ? 'hidden' : '';
});

// ── Bloquear feriados ─────────────────────────────────────────────────────────
document.getElementById('bp-dismiss-feriados')?.addEventListener('click', () => {
  document.getElementById('bp-feriados-box').style.display = 'none';
});
document.getElementById('bp-btn-feriados')?.addEventListener('click', async () => {
  const btn = document.getElementById('bp-btn-feriados');
  btn.textContent = 'Bloqueando…';
  btn.disabled    = true;
  try {
    const fd = new FormData();
    fd.set('action', 'block-feriados');
    fd.set('_redirect', window.location.pathname + window.location.search);
    const res = await fetch('/api/admin/bloqueos', { method: 'POST', body: fd });
    if (res.ok || res.redirected) {
      btn.textContent = '✓ Feriados bloqueados';
      btn.style.color = '#15803d';
      btn.style.borderColor = '#86efac';
    }
  } catch {
    btn.textContent = 'Error — intenta de nuevo';
    btn.disabled    = false;
  }
});

// ── Session panel: click on event ─────────────────────────────────────────────
document.querySelectorAll('.cal-event').forEach(el => {
  el.addEventListener('click', e => {
    e.stopPropagation();
    try { openSessionDetail(JSON.parse(el.dataset.booking || '{}')); }
    catch {}
  });
});

function openSessionDetail(b) {
  document.getElementById('sp-service').textContent = b.service_label || b.session_type;

  const isPaid = b.status === 'confirmed';
  const isManual = b.payment_method === 'manual';
  const isXfer   = b.payment_method === 'transferencia';
  const statusEl = document.getElementById('sp-status');
  statusEl.textContent = isPaid ? 'Confirmada' : 'Pendiente de pago';
  statusEl.className   = 'sp-status ' + (isPaid ? 'status-confirmed' : 'status-pending');

  document.getElementById('sp-patient-name').textContent = b.patient_name;
  document.getElementById('sp-patient-info').textContent = [b.patient_email, b.patient_phone].filter(Boolean).join('\n');

  // Meet link (stored as "Meet: https://..." in notes)
  const meetMatch = b.notes?.match(/Meet:\s*(https:\/\/\S+)/);
  const meetDiv  = document.getElementById('sp-meet-link');
  if (meetMatch) {
    document.getElementById('sp-meet-href').href = meetMatch[1];
    meetDiv.style.display = '';
  } else {
    meetDiv.style.display = 'none';
  }

  // Ver ficha link
  const fichaBtn = document.getElementById('sp-btn-ficha');
  if (b.patient_email) {
    fichaBtn.href = `/admin/pacientes?q=${encodeURIComponent(b.patient_email)}`;
  } else {
    fichaBtn.href = `/admin/pacientes?q=${encodeURIComponent(b.patient_name)}`;
  }

  // Amount & badge
  document.getElementById('sp-amount').textContent = formatCLP(b.amount);
  const badge = document.getElementById('sp-pay-badge');
  if (isPaid && isManual)  { badge.textContent='En consulta';   badge.className='sp-pay-badge badge-manual'; }
  else if (isPaid && isXfer){ badge.textContent='Transferencia'; badge.className='sp-pay-badge badge-transfer'; }
  else if (isPaid)         { badge.textContent='Pagado';        badge.className='sp-pay-badge badge-paid'; }
  else                     { badge.textContent='Pendiente';     badge.className='sp-pay-badge badge-pending'; }

  document.getElementById('sp-confirm-form').style.display = isPaid ? 'none' : 'block';
  document.getElementById('sp-confirm-id').value = b.id;

  // Date / time
  const dur  = b.duration_min ?? 50;
  const t5   = b.session_time.slice(0, 5);
  document.getElementById('sp-datetime').textContent = isoToLong(b.session_date);
  document.getElementById('sp-duration').textContent = `${t5} – ${addMins(t5, dur)} · ${dur} min`;

  const isOnline = b.session_type?.includes('online');
  document.getElementById('sp-location').innerHTML = isOnline
    ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;margin-right:3px"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>Sesión online'
    : '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;margin-right:3px"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>En mi consulta · Las Condes';

  // Reagendar pre-fill
  document.getElementById('sp-rsc-id').value   = b.id;
  document.getElementById('sp-rsc-date').value = b.session_date;
  document.getElementById('sp-rsc-time').value = t5;
  document.getElementById('sp-rsc-form').style.display = 'none';

  // Cancel
  document.getElementById('sp-cancel-id').value = b.id;

  openSessionPanel();
}

// ── Reagendar toggle ──────────────────────────────────────────────────────────
document.getElementById('sp-toggle-rsc')?.addEventListener('click', () => {
  const form = document.getElementById('sp-rsc-form');
  form.style.display = form.style.display === 'none' ? 'block' : 'none';
});
</script>
