// ── Booking panel: patient selector ──────────────────────────────────────────
const bpPatientSel = document.getElementById('bp-patient-sel');
const bpNewPatient = document.getElementById('bp-new-patient');
bpPatientSel?.addEventListener('change', () => {
  const isNew = bpPatientSel.value === '_new';
  bpNewPatient.style.display = isNew ? 'block' : 'none';
