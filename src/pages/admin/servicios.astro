---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const filtro = Astro.url.searchParams.get('filtro') ?? 'todos';
const saved  = Astro.url.searchParams.get('saved') === '1';
const editId = Astro.url.searchParams.get('edit') ?? null;

let query = supabase.from('services_catalog').select('*').order('sort_order').order('created_at');
if (filtro === 'visibles')  query = query.eq('visible', true);
if (filtro === 'ocultos')   query = query.eq('visible', false);
if (filtro === 'home')      query = query.eq('show_home', true);

const { data: services } = await query;

// Servicio a editar (si viene el parámetro edit)
const editService = editId ? services?.find(s => s.id === editId) ?? null : null;

const formatCLP = (n: number) =>
  new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);

const TYPE_LABEL: Record<string, string> = {
  individual: 'Individual', pareja: 'Pareja', grupal: 'Grupal', paquete: 'Paquete',
};
const MODALITY_LABEL: Record<string, string> = {
  presencial: 'Presencial', online: 'Online', ambos: 'Presencial + Online', domicilio: 'A domicilio',
};
const TYPE_ICON: Record<string, string> = {
  individual: '◯', pareja: '◎', grupal: '◉', paquete: '▣',
};
---

<AdminLayout title="Servicios" current="/admin/servicios">

  {saved && <div class="alert-success">✓ Servicio guardado correctamente.</div>}

  <!-- Cabecera -->
  <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
    <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
      {[
        { key: 'todos', label: 'Todos' },
        { key: 'visibles', label: 'Visibles' },
        { key: 'ocultos', label: 'Ocultos' },
        { key: 'home', label: 'En inicio' },
      ].map(f => (
        <a href={`/admin/servicios?filtro=${f.key}`}
           class={`btn btn-sm ${filtro === f.key ? 'btn-dark' : 'btn-outline'}`}>
          {f.label}
        </a>
      ))}
    </div>
    <div style="display:flex;gap:0.5rem;">
      <a href="/servicios" target="_blank" rel="noopener" class="btn btn-outline btn-sm">Ver página →</a>
      <button id="open-new" class="btn btn-dark">+ Nuevo servicio</button>
    </div>
  </div>

  <!-- Tabla de servicios -->
  <div class="card" style="padding:0;overflow:hidden;">
    <div style="overflow-x:auto;">
      {!services?.length ? (
        <div style="padding:3rem;text-align:center;">
          <p style="color:var(--stone);font-size:0.9rem;margin-bottom:1rem;">Sin servicios creados aún.</p>
          <button id="open-new-2" class="btn btn-dark btn-sm">Crear primer servicio</button>
        </div>
      ) : (
        <table>
          <thead>
            <tr>
              <th>Nombre del servicio</th>
              <th>Tipo</th>
              <th>Modalidad</th>
              <th>Duración</th>
              <th>Precio</th>
              <th>Inicio</th>
              <th>Visible</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {services.map(s => (
              <tr>
                <td>
                  <div style="display:flex;align-items:center;gap:0.75rem;">
                    {s.image_url && (
                      <img src={s.image_url} alt="" style="width:36px;height:36px;object-fit:cover;border-radius:4px;flex-shrink:0;" />
                    )}
                    <div>
                      <p style="font-weight:600;font-size:0.88rem;">{s.name}</p>
                      {s.location && <p style="font-size:0.72rem;color:var(--stone);">📍 {s.location}</p>}
                    </div>
                  </div>
                </td>
                <td style="font-size:0.82rem;color:var(--stone);">
                  {TYPE_ICON[s.type]} {TYPE_LABEL[s.type] ?? s.type}
                </td>
                <td style="font-size:0.82rem;color:var(--stone);">{MODALITY_LABEL[s.modality] ?? s.modality}</td>
                <td style="font-size:0.82rem;color:var(--stone);">
                  {s.modality === 'ambos' && s.duration_min_online && s.duration_min_presencial
                    ? `${s.duration_min_online}/${s.duration_min_presencial} min`
                    : `${s.duration_min} min`}
                </td>
                <td style="font-weight:600;font-size:0.88rem;">
                  {s.modality === 'ambos' && s.price_online && s.price_presencial
                    ? <span style="font-size:0.8rem;line-height:1.5;">{formatCLP(s.price_online)}<br/><span style="color:var(--stone);font-weight:500;">pres. {formatCLP(s.price_presencial)}</span></span>
                    : formatCLP(s.price)}
                </td>
                <td>
                  <form method="POST" action="/api/admin/services" style="margin:0;">
                    <input type="hidden" name="action" value="toggle_home" />
                    <input type="hidden" name="id" value={s.id} />
                    <input type="hidden" name="current" value={String(s.show_home)} />
                    <input type="hidden" name="redirect" value={`/admin/servicios?filtro=${filtro}`} />
                    <button type="submit" title={s.show_home ? 'Quitar del inicio' : 'Mostrar en inicio'}
                      style={`background:none;border:none;cursor:pointer;font-size:1.1rem;${s.show_home ? 'color:var(--forest);' : 'color:var(--dust);'}`}>
                      ★
                    </button>
                  </form>
                </td>
                <td>
                  <form method="POST" action="/api/admin/services" style="margin:0;">
                    <input type="hidden" name="action" value="toggle_visible" />
                    <input type="hidden" name="id" value={s.id} />
                    <input type="hidden" name="current" value={String(s.visible)} />
                    <input type="hidden" name="redirect" value={`/admin/servicios?filtro=${filtro}`} />
                    <button type="submit" title={s.visible ? 'Ocultar' : 'Publicar'}
                      style={`background:none;border:none;cursor:pointer;font-size:0.75rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;padding:0.2rem 0.5rem;border-radius:99px;${s.visible ? 'background:#f0fdf4;color:var(--green);' : 'background:var(--warm);color:var(--stone);'}`}>
                      {s.visible ? 'Visible' : 'Oculto'}
                    </button>
                  </form>
                </td>
                <td>
                  <div style="display:flex;gap:0.4rem;align-items:center;">
                    <a href={`/admin/servicios?edit=${s.id}`} class="btn btn-outline btn-sm">Editar</a>
                    <div style="position:relative;" class="dropdown-wrap">
                      <button class="btn btn-outline btn-sm dropdown-btn">▾</button>
                      <div class="dropdown-menu" style="display:none;position:absolute;right:0;top:100%;background:white;border:1px solid var(--dust);border-radius:var(--radius);box-shadow:var(--shadow);min-width:180px;z-index:50;padding:0.4rem 0;">
                        <a href={`https://wa.me/?text=${encodeURIComponent(`${s.name} — ${formatCLP(s.price)} · psicologavalentinaorellana.com/agenda`)}`}
                           target="_blank"
                           style="display:block;padding:0.6rem 1rem;font-size:0.82rem;color:var(--ink);text-decoration:none;">
                          Compartir WhatsApp
                        </a>
                        <hr style="border:none;border-top:1px solid var(--warm);margin:0.25rem 0;" />
                        <form method="POST" action="/api/admin/services" onsubmit="return confirm('¿Eliminar este servicio?')">
                          <input type="hidden" name="action" value="delete" />
                          <input type="hidden" name="id" value={s.id} />
                          <input type="hidden" name="redirect" value={`/admin/servicios?filtro=${filtro}`} />
                          <button type="submit" style="width:100%;text-align:left;background:none;border:none;padding:0.6rem 1rem;font-size:0.82rem;cursor:pointer;color:var(--red);">
                            Eliminar
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>

  <p style="margin-top:0.75rem;font-size:0.78rem;color:var(--stone);">
    {services?.length ?? 0} servicio{services?.length !== 1 ? 's' : ''} · ★ = carrusel inicio · Visible = página /servicios
  </p>

</AdminLayout>

<!-- Modal crear / editar servicio -->
<div id="modal-service" style={`display:${editService ? 'flex' : 'none'};position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:100;align-items:center;justify-content:center;padding:1rem;`}>
  <div style="background:white;width:100%;max-width:560px;max-height:92vh;overflow-y:auto;padding:2rem;border-radius:6px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
      <p style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;" id="modal-service-title">
        {editService ? 'Editar servicio' : 'Nuevo servicio'}
      </p>
      <button id="close-service-modal" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--stone);">✕</button>
    </div>

    <form method="POST" action="/api/admin/services" enctype="multipart/form-data" style="display:flex;flex-direction:column;gap:1rem;">
      <input type="hidden" name="action" value={editService ? 'update' : 'create'} />
      {editService && <input type="hidden" name="id" value={editService.id} />}
      <input type="hidden" name="redirect" value="/admin/servicios?saved=1" />

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">

        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.3rem;">Nombre del servicio *</label>
          <input type="text" name="name" value={editService?.name ?? ''} required placeholder="Ej: Sesión individual presencial Las Condes" />
        </div>

        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Tipo</label>
          <select name="type">
            {(['individual','pareja','grupal','paquete'] as const).map(t => (
              <option value={t} selected={editService?.type === t}>{TYPE_LABEL[t]}</option>
            ))}
          </select>
        </div>

        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Modalidad</label>
          <select name="modality">
            {(['presencial','online','ambos','domicilio'] as const).map(m => (
              <option value={m} selected={editService?.modality === m}>{MODALITY_LABEL[m] ?? m}</option>
            ))}
          </select>
        </div>

        {/* ── Precio y duración: simple (presencial/online) o dual (ambos) ── */}

        <div id="price-single" style={editService?.modality === 'ambos' ? 'display:none' : ''}>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Precio (CLP)</label>
          <input type="number" name="price"
            value={editService?.modality !== 'ambos' ? (editService?.price ?? '') : ''}
            min="0" step="1000" placeholder="55000" />
        </div>

        <div id="duration-single" style={editService?.modality === 'ambos' ? 'display:none' : ''}>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Duración (minutos)</label>
          <input type="number" name="duration_min"
            value={editService?.modality !== 'ambos' ? (editService?.duration_min ?? 50) : 50}
            min="10" step="5" />
        </div>

        <div id="price-dual" style={`grid-column:1/-1;display:${editService?.modality === 'ambos' ? 'grid' : 'none'};grid-template-columns:1fr 1fr;gap:1rem;`}>
          <div>
            <label class="label" style="display:block;margin-bottom:0.3rem;">Precio Online (CLP)</label>
            <input type="number" name="price_online"
              value={editService?.price_online ?? ''}
              min="0" step="1000" placeholder="55000" />
          </div>
          <div>
            <label class="label" style="display:block;margin-bottom:0.3rem;">Precio Presencial (CLP)</label>
            <input type="number" name="price_presencial"
              value={editService?.price_presencial ?? ''}
              min="0" step="1000" placeholder="65000" />
          </div>
        </div>

        <div id="duration-dual" style={`grid-column:1/-1;display:${editService?.modality === 'ambos' ? 'grid' : 'none'};grid-template-columns:1fr 1fr;gap:1rem;`}>
          <div>
            <label class="label" style="display:block;margin-bottom:0.3rem;">Duración Online (min)</label>
            <input type="number" name="duration_min_online"
              value={editService?.duration_min_online ?? 50}
              min="10" step="5" />
          </div>
          <div>
            <label class="label" style="display:block;margin-bottom:0.3rem;">Duración Presencial (min)</label>
            <input type="number" name="duration_min_presencial"
              value={editService?.duration_min_presencial ?? 50}
              min="10" step="5" />
          </div>
        </div>

        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.3rem;">Ubicación (presencial)</label>
          <input type="text" name="location" value={editService?.location ?? ''} placeholder="Las Condes, Vitacura, La Reina..." />
        </div>

        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.3rem;">Descripción</label>
          <textarea name="description" rows="3" placeholder="Descripción del servicio...">{editService?.description ?? ''}</textarea>
        </div>

        {/* ── Boleta de honorarios ── */}
        <div style="grid-column:1/-1;border-top:1px solid var(--warm);padding-top:1rem;margin-top:0.25rem;">
          <p class="label" style="display:block;margin-bottom:0.6rem;font-weight:700;">Boleta de honorarios</p>

          <label class="label" style="display:block;margin-bottom:0.3rem;">Glosa de la boleta (para el SII)</label>
          <input type="text" name="fonasa_description" value={(editService as Record<string, unknown>)?.fonasa_description as string ?? ''}
            placeholder="Ej: Sesión psicoterapia individual" />
          <p style="font-size:0.72rem;color:var(--stone);margin-top:0.3rem;">
            Es el texto que aparece como detalle en la boleta emitida. No se muestra en el sitio.
          </p>

          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.85rem;margin-top:0.75rem;">
            <input type="checkbox" name="boleta_auto" style="width:auto;" checked={(editService as Record<string, unknown>)?.boleta_auto as boolean ?? false} />
            Emitir la boleta automáticamente al confirmarse el pago
          </label>
          <p style="font-size:0.72rem;color:var(--stone);margin-top:0.3rem;margin-left:1.5rem;">
            Requiere que el paciente tenga RUT en su ficha. También se le envía por correo.
          </p>
        </div>

        {/* ── Agendamiento ── */}
        <div style="grid-column:1/-1;border-top:1px solid var(--warm);padding-top:1rem;">
          <p class="label" style="display:block;margin-bottom:0.6rem;font-weight:700;">Agendamiento</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div>
              <label class="label" style="display:block;margin-bottom:0.3rem;">Horas mínimas de anticipación</label>
              <input type="number" name="min_hours" value={(editService as Record<string, unknown>)?.min_hours as number ?? ''}
                min="0" step="1" placeholder="Ej: 24" />
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:0.6rem;margin-top:0.75rem;">
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.85rem;">
              <input type="checkbox" name="waitlist" style="width:auto;" checked={(editService as Record<string, unknown>)?.waitlist as boolean ?? false} />
              Activar lista de espera cuando no haya horas disponibles
            </label>
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.85rem;">
              <input type="checkbox" name="prepago" style="width:auto;" checked={(editService as Record<string, unknown>)?.prepago as boolean ?? false} />
              Prepago (el paciente paga al momento de agendar)
            </label>
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.85rem;">
              <input type="checkbox" name="pago_requerido" style="width:auto;" checked={(editService as Record<string, unknown>)?.pago_requerido as boolean ?? false} />
              Pago requerido para entrar a la sesión (online)
            </label>
          </div>
        </div>

        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.5rem;">Imagen del servicio</label>

          <!-- Preview -->
          <div id="img-preview-wrap" style={`display:${editService?.image_url ? 'block' : 'none'};margin-bottom:0.75rem;position:relative;width:100%;height:160px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--dust);`}>
            <img id="img-preview" src={editService?.image_url ?? ''} alt="" style="width:100%;height:100%;object-fit:cover;" />
            <button type="button" id="btn-remove-img"
              style="position:absolute;top:0.5rem;right:0.5rem;background:rgba(0,0,0,.55);border:none;color:white;border-radius:50%;width:28px;height:28px;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;line-height:1;">
              ✕
            </button>
          </div>

          <!-- Zona de carga -->
          <div id="upload-zone"
            style={`border:2px dashed var(--dust);border-radius:var(--radius);padding:1.5rem;text-align:center;cursor:pointer;transition:border-color .2s;${editService?.image_url ? 'display:none' : ''}`}>
            <p style="font-size:0.85rem;color:var(--stone);margin-bottom:0.4rem;">Arrastra una imagen o</p>
            <button type="button" id="btn-pick-img" class="btn btn-outline btn-sm">Seleccionar archivo</button>
            <p style="font-size:0.72rem;color:var(--dust);margin-top:0.5rem;">JPG, PNG, WebP — máx. 3 MB</p>
          </div>

          <!-- Inputs ocultos -->
          <input type="file" id="image-file-input" name="image_file" accept="image/jpeg,image/png,image/webp,image/gif" style="display:none;" />
          <input type="hidden" name="image_url" id="image-url-hidden" value={editService?.image_url ?? ''} />

          <!-- Estado de carga -->
          <p id="upload-status" style="display:none;font-size:0.8rem;color:var(--forest);margin-top:0.4rem;"></p>
        </div>

        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Orden (menor = primero)</label>
          <input type="number" name="sort_order" value={editService?.sort_order ?? 0} min="0" />
        </div>

        <div style="display:flex;flex-direction:column;gap:0.75rem;justify-content:flex-end;">
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.85rem;">
            <input type="checkbox" name="visible" style="width:auto;" checked={editService?.visible ?? true} />
            Mostrar en página Servicios
          </label>
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.85rem;">
            <input type="checkbox" name="show_home" style="width:auto;" checked={editService?.show_home ?? false} />
            Mostrar en carrusel del inicio
          </label>
        </div>

      </div>

      <button type="submit" class="btn btn-dark btn-lg" style="width:100%;justify-content:center;margin-top:0.5rem;">
        {editService ? 'Guardar cambios' : 'Crear servicio'}
      </button>
    </form>
  </div>
</div>

<style>
  .dropdown-menu { display: none; }
</style>

<script>
  const modal    = document.getElementById('modal-service');
  const closeBtn = document.getElementById('close-service-modal');

  // ── Toggle precio/duración según modalidad ──────────────────────────────
  const priceSingle    = document.getElementById('price-single');
  const durationSingle = document.getElementById('duration-single');
  const priceDual      = document.getElementById('price-dual');
  const durationDual   = document.getElementById('duration-dual');

  function togglePriceFields(modality) {
    const isAmbos = modality === 'ambos';
    priceSingle.style.display    = isAmbos ? 'none'  : '';
    durationSingle.style.display = isAmbos ? 'none'  : '';
    priceDual.style.display      = isAmbos ? 'grid'  : 'none';
    durationDual.style.display   = isAmbos ? 'grid'  : 'none';
  }

  const modalitySelect = modal?.querySelector('[name="modality"]');
  modalitySelect?.addEventListener('change', () => togglePriceFields(modalitySelect.value));

  const openModal = () => {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    // Para nuevo servicio el select empieza en "presencial"
    if (modalitySelect) togglePriceFields(modalitySelect.value);
  };
  const closeModal = () => { modal.style.display = 'none'; document.body.style.overflow = ''; };

  document.getElementById('open-new')?.addEventListener('click', openModal);
  document.getElementById('open-new-2')?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  // ── Upload de imagen ────────────────────────────────────────────────────
  const fileInput     = document.getElementById('image-file-input');
  const btnPick       = document.getElementById('btn-pick-img');
  const btnRemove     = document.getElementById('btn-remove-img');
  const previewWrap   = document.getElementById('img-preview-wrap');
  const previewImg    = document.getElementById('img-preview');
  const uploadZone    = document.getElementById('upload-zone');
  const hiddenUrl     = document.getElementById('image-url-hidden');
  const uploadStatus  = document.getElementById('upload-status');

  btnPick?.addEventListener('click', () => fileInput?.click());

  // Drag & drop
  uploadZone?.addEventListener('dragover',  e => { e.preventDefault(); uploadZone.style.borderColor = 'var(--forest)'; });
  uploadZone?.addEventListener('dragleave', () => { uploadZone.style.borderColor = 'var(--dust)'; });
  uploadZone?.addEventListener('drop', e => {
    e.preventDefault();
    uploadZone.style.borderColor = 'var(--dust)';
    const file = e.dataTransfer?.files?.[0];
    if (file) handleFile(file);
  });

  fileInput?.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) handleFile(file);
  });

  async function handleFile(file) {
    if (file.size > 3 * 1024 * 1024) {
      uploadStatus.textContent  = '⚠️ El archivo supera los 3 MB.';
      uploadStatus.style.color  = 'var(--red)';
      uploadStatus.style.display = '';
      return;
    }

    // Preview local inmediato
    const reader = new FileReader();
    reader.onload = e => {
      previewImg.src           = e.target.result;
      previewWrap.style.display = '';
      uploadZone.style.display  = 'none';
    };
    reader.readAsDataURL(file);

    // Subir al servidor
    uploadStatus.textContent  = 'Subiendo imagen…';
    uploadStatus.style.color  = 'var(--forest)';
    uploadStatus.style.display = '';

    const fd = new FormData();
    fd.append('file', file);

    try {
      const res  = await fetch('/api/admin/upload-image', { method: 'POST', body: fd });
      const data = await res.json();

      if (!res.ok || !data.url) {
        uploadStatus.textContent = '⚠️ Error al subir: ' + (data.error ?? 'intenta de nuevo.');
        uploadStatus.style.color = 'var(--red)';
        return;
      }

      hiddenUrl.value           = data.url;
      previewImg.src            = data.url;
      uploadStatus.textContent  = '✓ Imagen subida correctamente.';
      uploadStatus.style.color  = 'var(--green)';
    } catch {
      uploadStatus.textContent = '⚠️ Error de conexión al subir imagen.';
      uploadStatus.style.color = 'var(--red)';
    }
  }

  // Quitar imagen
  btnRemove?.addEventListener('click', () => {
    hiddenUrl.value           = '';
    previewImg.src            = '';
    previewWrap.style.display  = 'none';
    uploadZone.style.display   = '';
    uploadStatus.style.display = 'none';
    if (fileInput) fileInput.value = '';
  });

  // ── Dropdowns con position:fixed para salir del overflow ───────────────────
  function closeAllDropdowns() {
    document.querySelectorAll('.dropdown-menu').forEach((m: Element) => {
      (m as HTMLElement).style.display = 'none';
    });
  }

  document.querySelectorAll('.dropdown-btn').forEach((btn: Element) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const menu = (btn as HTMLElement).nextElementSibling as HTMLElement | null;
      if (!menu) return;

      const isOpen = menu.style.display === 'block';
      closeAllDropdowns();
      if (isOpen) return;

      const rect = (btn as HTMLElement).getBoundingClientRect();
      menu.style.position = 'fixed';
      menu.style.top      = (rect.bottom + 4) + 'px';
      menu.style.left     = 'auto';
      menu.style.right    = (window.innerWidth - rect.right) + 'px';
      menu.style.zIndex   = '9999';
      menu.style.display  = 'block';
    });
  });

  document.addEventListener('click', closeAllDropdowns);
</script>
