---
export const prerender = false;

// Si ya tiene sesión, redirigir al panel
const token    = Astro.cookies.get('vo_admin_token')?.value ?? '';
const expected = import.meta.env.ADMIN_SECRET;
if (expected && token === expected) {
  return Astro.redirect('/admin');
}

const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Acceso · Panel Valentina Orellana</title>
  <link rel="icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #F7F5F0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }
    .card {
      background: white;
      border: 1px solid #E8E4DC;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 360px;
    }
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: 1.75rem;
      color: #1A1916;
      margin-bottom: 0.25rem;
    }
    p.sub {
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #6B6860;
      margin-bottom: 2rem;
    }
    label {
      display: block;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #6B6860;
      margin-bottom: 0.4rem;
    }
    input[type="password"] {
      width: 100%;
      border: none;
      border-bottom: 1px solid #E8E4DC;
      padding: 0.6rem 0;
      font-size: 0.875rem;
      font-family: 'Inter', sans-serif;
      color: #1A1916;
      background: transparent;
      outline: none;
      transition: border-color 0.2s;
    }
    input[type="password"]:focus { border-color: #1A1916; }
    button {
      margin-top: 2rem;
      width: 100%;
      background: #1A1916;
      color: white;
      border: none;
      padding: 0.85rem;
      font-family: 'Inter', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s;
    }
    button:hover { background: #A8906C; }
    .error {
      margin-top: 1rem;
      font-size: 0.75rem;
      color: #ef4444;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>Panel Admin</h1>
    <p class="sub">Ps. Valentina Orellana</p>

    <form method="POST" action="/api/admin/login">
      <label for="password">Contraseña</label>
      <input id="password" name="password" type="password" required autocomplete="current-password" autofocus />
      <button type="submit">Ingresar</button>
      {error && <p class="error">Contraseña incorrecta.</p>}
    </form>
  </div>
</body>
</html>
