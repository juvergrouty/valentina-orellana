---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const q      = Astro.url.searchParams.get('q') ?? '';
const filtro = Astro.url.searchParams.get('filtro') ?? 'todos';
const saved  = Astro.url.searchParams.get('saved') === '1';

// ── Pacientes ──────────────────────────────────────────────────────────────
let query = supabase.from('patients').select('*').order('name');
if (filtro === 'activos')   query = query.eq('active', true);
if (filtro === 'inactivos') query = query.eq('active', false);
if (q) query = query.or(`name.ilike.%${q}%,email.ilike.%${q}%,phone.ilike.%${q}%,rut.ilike.%${q}%`);

const { data: patients } = await query;

// Conteos para los tabs
const [{ count: countAll }, { count: countActive }, { count: countInactive }] = await Promise.all([
  supabase.from('patients').select('*', { count: 'exact', head: true }),
  supabase.from('patients').select('*', { count: 'exact', head: true }).eq('active', true),
  supabase.from('patients').select('*', { count: 'exact', head: true }).eq('active', false),
]);

// ── Reservas (para última/próxima sesión y cobros) ─────────────────────────
const todayStr = new Date().toISOString().split('T')[0];
const { data: bookings } = await supabase
  .from('bookings')
  .select('patient_email, session_date, status, amount')
  .neq('status', 'cancelled');

type Stat = { last: string | null; next: string | null; due: number };
const statByEmail: Record<string, Stat> = {};
(bookings ?? []).forEach(b => {
  const key = (b.patient_email ?? '').toLowerCase();
  if (!key) return;
  const s = (statByEmail[key] ??= { last: null, next: null, due: 0 });
  if (b.session_date <= todayStr) {
    if (!s.last || b.session_date > s.last) s.last = b.session_date;
  } else {
    if (!s.next || b.session_date < s.next) s.next = b.session_date;
  }
  if (b.status !== 'confirmed' && b.amount) s.due += b.amount;
});

// ── Helpers ────────────────────────────────────────────────────────────────
const MONTHS = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
function fmtDate(iso: string | null): string {
  if (!iso) return '';
  const [y, m, d] = iso.split('-').map(Number);
  return `${String(d).padStart(2,'0')} ${MONTHS[m-1]} ${y}`;
}
const formatCLP = (n: number) =>
  new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);
function waLink(phone: string | null): string | null {
  if (!phone) return null;
  const digits = phone.replace(/[^\d]/g, '');
  return digits ? `https://wa.me/${digits.startsWith('56') ? digits : '56' + digits}` : null;
}

const TABS = [
  { key: 'todos',      label: 'Todos',      count: countAll      ?? 0 },
  { key: 'activos',    label: 'Activos',    count: countActive   ?? 0 },
  { key: 'inactivos',  label: 'Inactivos',  count: countInactive ?? 0 },
  { key: 'eliminados', label: 'Eliminados', count: 0             },
];
---

<AdminLayout title="Pacientes" current="/admin/pacientes" fullHeight={true}>

  <div class="pac-wrap">

    {saved && <div class="alert-success" style="margin:1rem 1.5rem 0;">✓ Paciente guardado correctamente.</div>}

    <!-- Título -->
    <div class="pac-head">
      <h1>Pacientes</h1>
    </div>

    <!-- Tabs -->
    <div class="pac-tabs">
      {TABS.map(t => (
        <a href={`/admin/pacientes?filtro=${t.key}`}
           class={`pac-tab${filtro === t.key ? ' active' : ''}`}>
          {t.label} <span class="pac-tab-count">({t.count})</span>
        </a>
      ))}
    </div>

    <!-- Barra búsqueda + acciones -->
    <div class="pac-toolbar">
      <form method="GET" action="/admin/pacientes" class="pac-search">
        <input type="hidden" name="filtro" value={filtro} />
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" name="q" value={q} placeholder="Buscar por nombre, RUT, teléfono o correo" />
      </form>
      <div class="pac-actions">
        <button class="pac-icon-btn" title="Interesados (próximamente)" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
        </button>
        <button class="pac-icon-btn" title="Plantillas (próximamente)" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 002-2V4a2 2 0 00-2-2H8a2 2 0 00-2 2v16a2 2 0 01-2 2zm0 0a2 2 0 01-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8M15 18h-5M10 6h8v4h-8z"/></svg>
        </button>
        <button id="open-new-patient" class="btn btn-primary btn-sm pac-add-btn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Añadir nuevo
        </button>
      </div>
    </div>

    <!-- Tabla -->
    <div class="pac-table-scroll">
      {!patients?.length ? (
        <p class="pac-empty">{q ? `Sin resultados para "${q}"` : 'No hay pacientes aún.'}</p>
      ) : (
        <table class="pac-table">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Última sesión</th>
              <th>Próxima sesión</th>
              <th>Pagos</th>
              <th style="text-align:right;">Total por cobrar</th>
              <th style="text-align:right;">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {patients.map(p => {
              const st  = statByEmail[(p.email ?? '').toLowerCase()] ?? { last: null, next: null, due: 0 };
              const wa  = waLink(p.phone);
              const due = st.due > 0;
              return (
                <tr class="pac-row" data-href={`/admin/pacientes/${p.id}`}>
                  <td>
                    <span class="pac-name">{p.name}</span>
                    {p.rut && <span class="pac-rut">{p.rut}</span>}
                  </td>
                  <td class="pac-muted">{fmtDate(st.last) || '—'}</td>
                  <td class="pac-muted">{fmtDate(st.next) || '—'}</td>
                  <td>
                    <span class={`pac-pay ${due ? 'pay-due' : 'pay-ok'}`}>
                      {due ? 'Por pagar' : 'Al día'}
                    </span>
                  </td>
                  <td style="text-align:right;">
                    {due ? <span class="pac-due-amount">{formatCLP(st.due)}</span> : <span class="pac-muted">—</span>}
                  </td>
                  <td>
                    <div class="pac-row-actions">
                      <a href="/admin/agenda" class="pac-act" title="Agendar" onclick="event.stopPropagation()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f5ce8" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                      </a>
                      {wa && (
                        <a href={wa} target="_blank" rel="noopener" class="pac-act" title="WhatsApp" onclick="event.stopPropagation()">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="#25d366"><path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-1.5-.7-2.5-1.3-3.4-3-.3-.4.3-.4.7-1.3.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.2 5 4.4.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 00-8.5 15.2L2 22l4.9-1.3A10 10 0 1012 2z"/></svg>
                        </a>
                      )}
                      <div class="pac-menu-wrap">
                        <button class="pac-act pac-menu-btn" title="Más" onclick="event.stopPropagation()">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg>
                        </button>
                        <div class="pac-menu">
                          <a href={`/admin/pacientes/${p.id}`} class="pac-menu-item">Ver ficha</a>
                          <a href={`/admin/pacientes/${p.id}#editar`} class="pac-menu-item">Editar</a>
                          <hr />
                          <form method="POST" action="/api/admin/patients" style="margin:0;">
                            <input type="hidden" name="action" value="archive" />
                            <input type="hidden" name="id" value={p.id} />
                            <input type="hidden" name="active" value={String(p.active)} />
                            <input type="hidden" name="redirect" value={`/admin/pacientes?filtro=${filtro}`} />
                            <button type="submit" class="pac-menu-item">{p.active ? 'Dar de baja' : 'Dar de alta'}</button>
                          </form>
                          <form method="POST" action="/api/admin/patients" onsubmit="return confirm('¿Eliminar este paciente? Esta acción no se puede deshacer.')" style="margin:0;">
                            <input type="hidden" name="action" value="delete" />
                            <input type="hidden" name="id" value={p.id} />
                            <input type="hidden" name="redirect" value={`/admin/pacientes?filtro=${filtro}`} />
                            <button type="submit" class="pac-menu-item pac-menu-danger">Eliminar</button>
                          </form>
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </div>

    <div class="pac-footer">
      {patients?.length ?? 0} paciente{patients?.length !== 1 ? 's' : ''}
    </div>

  </div>

</AdminLayout>

<!-- Modal nuevo paciente -->
<div id="modal-new-patient" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:100;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:white;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;padding:2rem;border-radius:8px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
      <p style="font-size:1.15rem;font-weight:600;">Nuevo paciente</p>
      <button id="close-new-patient" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--stone);">✕</button>
    </div>

    <form method="POST" action="/api/admin/patients" style="display:flex;flex-direction:column;gap:1rem;">
      <input type="hidden" name="action" value="create" />
      <input type="hidden" name="redirect" value="/admin/pacientes?saved=1" />

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.3rem;">Nombre completo *</label>
          <input type="text" name="name" required placeholder="Nombre completo" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Email</label>
          <input type="email" name="email" placeholder="correo@ejemplo.cl" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Teléfono</label>
          <input type="tel" name="phone" placeholder="+56 9 XXXX XXXX" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">RUT</label>
          <input type="text" name="rut" placeholder="12.345.678-9" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Fecha de nacimiento</label>
          <input type="date" name="birthdate" />
        </div>
        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.3rem;">Dirección</label>
          <input type="text" name="address" placeholder="Dirección" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Contacto emergencia</label>
          <input type="text" name="emergency_name" placeholder="Nombre" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Tel. emergencia</label>
          <input type="tel" name="emergency_phone" placeholder="+56 9 XXXX XXXX" />
        </div>
        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.3rem;">Notas generales</label>
          <textarea name="notes" rows="3" placeholder="Motivo de consulta inicial, antecedentes..."></textarea>
        </div>
      </div>

      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:0.5rem;">
        Crear paciente
      </button>
    </form>
  </div>
</div>

<style>
.pac-wrap { display: flex; flex-direction: column; height: 100vh; overflow: hidden; background: white; }

.pac-head { padding: 1.25rem 1.5rem 0.5rem; }
.pac-head h1 { font-size: 1.6rem; font-weight: 700; color: #111827; }

/* Tabs */
.pac-tabs { display: flex; gap: 0.25rem; padding: 0 1.5rem; border-bottom: 1px solid #e5e7eb; }
.pac-tab {
  padding: 0.6rem 0.9rem; font-size: 0.85rem; font-weight: 500; color: #6b7280;
  text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap;
}
.pac-tab:hover { color: #111827; }
.pac-tab.active { color: #4f5ce8; border-bottom-color: #4f5ce8; font-weight: 600; }
.pac-tab-count { color: #9ca3af; font-weight: 400; }
.pac-tab.active .pac-tab-count { color: #4f5ce8; }

/* Toolbar */
.pac-toolbar { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1.5rem; flex-wrap: wrap; }
.pac-search {
  flex: 1; min-width: 240px; display: flex; align-items: center; gap: 0.5rem;
  border: 1px solid #d1d5db; border-radius: 8px; padding: 0 0.75rem; background: white;
}
.pac-search svg { flex-shrink: 0; }
.pac-search input {
  flex: 1; border: none !important; background: transparent !important;
  padding: 0.55rem 0 !important; font-size: 0.875rem !important; box-shadow: none !important;
}
.pac-actions { display: flex; align-items: center; gap: 0.5rem; }
.pac-icon-btn {
  width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;
  border: 1px solid #d1d5db; border-radius: 8px; background: white; color: #6b7280; cursor: pointer;
}
.pac-icon-btn:hover:not(:disabled) { background: #f9fafb; }
.pac-icon-btn:disabled { opacity: 0.4; cursor: default; }
.pac-add-btn { height: 38px; }

/* Tabla */
.pac-table-scroll { flex: 1; min-height: 0; overflow: auto; }
.pac-table { width: 100%; border-collapse: collapse; }
.pac-table thead th {
  position: sticky; top: 0; z-index: 5; background: #f9fafb;
  text-align: left; font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase;
  color: #6b7280; font-weight: 600; padding: 0.7rem 1.5rem; border-bottom: 1px solid #e5e7eb;
}
.pac-table tbody td { padding: 0.95rem 1.5rem; border-bottom: 1px solid #f3f4f6; font-size: 0.875rem; vertical-align: middle; }
.pac-row { cursor: pointer; transition: background .1s; }
.pac-row:hover td { background: #fafbff; }
.pac-name { font-weight: 600; color: #111827; display: block; }
.pac-rut { font-size: 0.75rem; color: #9ca3af; }
.pac-muted { color: #6b7280; }

.pac-pay { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 99px; font-size: 0.75rem; font-weight: 600; }
.pay-ok  { background: #f0fdf4; color: #15803d; }
.pay-due { background: #fef2f2; color: #dc2626; }
.pac-due-amount { font-weight: 700; color: #111827; }

/* Acciones */
.pac-row-actions { display: flex; align-items: center; justify-content: flex-end; gap: 0.35rem; }
.pac-act {
  width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
  border-radius: 7px; background: none; border: none; cursor: pointer; color: #9ca3af; text-decoration: none;
}
.pac-act:hover { background: #f3f4f6; }
.pac-menu-wrap { position: relative; }
.pac-menu {
  display: none; position: absolute; right: 0; top: calc(100% + 4px);
  background: white; border: 1px solid #e5e7eb; border-radius: 8px;
  box-shadow: 0 4px 16px rgba(0,0,0,.1); min-width: 170px; z-index: 30; padding: 0.3rem 0;
}
.pac-menu.show { display: block; }
.pac-menu hr { border: none; border-top: 1px solid #f3f4f6; margin: 0.25rem 0; }
.pac-menu-item {
  display: block; width: 100%; text-align: left; background: none; border: none;
  padding: 0.55rem 0.9rem; font-size: 0.82rem; color: #374151; cursor: pointer; text-decoration: none;
}
.pac-menu-item:hover { background: #f9fafb; }
.pac-menu-danger { color: #dc2626; }

.pac-empty { padding: 3rem; text-align: center; color: #9ca3af; font-size: 0.9rem; }
.pac-footer { padding: 0.75rem 1.5rem; font-size: 0.78rem; color: #9ca3af; border-top: 1px solid #f3f4f6; flex-shrink: 0; }
</style>

<script>
  // Modal nuevo paciente
  const modal    = document.getElementById('modal-new-patient');
  const openBtn  = document.getElementById('open-new-patient');
  const closeBtn = document.getElementById('close-new-patient');
  openBtn?.addEventListener('click', () => { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; });
  const close = () => { modal.style.display = 'none'; document.body.style.overflow = ''; };
  closeBtn?.addEventListener('click', close);
  modal?.addEventListener('click', e => { if (e.target === modal) close(); });

  // Click en fila → ficha (excepto en botones de acción)
  document.querySelectorAll('.pac-row').forEach(row => {
    row.addEventListener('click', e => {
      if (e.target.closest('.pac-row-actions')) return;
      const href = row.dataset.href;
      if (href) window.location = href;
    });
  });

  // Menú "..." de cada fila
  function closeAllMenus() {
    document.querySelectorAll('.pac-menu.show').forEach(m => m.classList.remove('show'));
  }
  document.querySelectorAll('.pac-menu-btn').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const menu = btn.nextElementSibling;
      const isOpen = menu.classList.contains('show');
      closeAllMenus();
      if (!isOpen) menu.classList.add('show');
    });
  });
  document.addEventListener('click', closeAllMenus);
</script>
