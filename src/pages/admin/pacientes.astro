---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const q = Astro.url.searchParams.get('q') ?? '';
const filtro = Astro.url.searchParams.get('filtro') ?? 'activos';

let query = supabase.from('patients').select('*').order('name');
if (filtro === 'activos')   query = query.eq('active', true);
if (filtro === 'archivados') query = query.eq('active', false);
if (q) query = query.ilike('name', `%${q}%`);

const { data: patients } = await query;

const saved = Astro.url.searchParams.get('saved') === '1';

function initials(name: string) {
  return name.split(' ').slice(0,2).map(w => w[0]).join('').toUpperCase();
}
function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('es-CL', { day:'2-digit', month:'short', year:'numeric' });
}
---

<AdminLayout title="Pacientes" current="/admin/pacientes">

  {saved && <div class="alert-success">✓ Paciente guardado correctamente.</div>}

  <!-- Barra de búsqueda + acciones -->
  <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
    <form method="GET" action="/admin/pacientes" style="display:flex;gap:0.75rem;flex:1;min-width:200px;max-width:440px;">
      <input type="hidden" name="filtro" value={filtro} />
      <input type="search" name="q" value={q} placeholder="Buscar paciente..."
        style="flex:1;" />
      <button type="submit" class="btn btn-outline btn-sm">Buscar</button>
    </form>

    <div style="display:flex;gap:0.5rem;align-items:center;">
      <a href="/admin/pacientes?filtro=activos"   class={`btn btn-sm ${filtro==='activos'   ? 'btn-dark' : 'btn-outline'}`}>Activos</a>
      <a href="/admin/pacientes?filtro=archivados" class={`btn btn-sm ${filtro==='archivados' ? 'btn-dark' : 'btn-outline'}`}>Archivados</a>
      <button id="open-new-patient" class="btn btn-dark btn-sm">+ Nuevo paciente</button>
    </div>
  </div>

  <!-- Lista de pacientes -->
  <div class="card" style="padding:0;overflow:hidden;">
    {!patients?.length ? (
      <p style="padding:2rem;text-align:center;color:var(--stone);font-size:0.9rem;">
        {q ? `Sin resultados para "${q}"` : 'No hay pacientes aún.'}
      </p>
    ) : (
      <table>
        <thead>
          <tr>
            <th>Paciente</th>
            <th>Contacto</th>
            <th>RUT</th>
            <th>Desde</th>
            <th>Estado</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {patients.map(p => (
            <tr style="cursor:pointer;" onclick={`window.location='/admin/pacientes/${p.id}'`}>
              <td>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                  <div style="width:36px;height:36px;border-radius:50%;background:var(--forest);color:white;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:600;flex-shrink:0;">
                    {initials(p.name)}
                  </div>
                  <div>
                    <p style="font-weight:600;font-size:0.9rem;">{p.name}</p>
                    {p.email && <p style="font-size:0.75rem;color:var(--stone);">{p.email}</p>}
                  </div>
                </div>
              </td>
              <td style="color:var(--stone);font-size:0.85rem;">{p.phone ?? '—'}</td>
              <td style="color:var(--stone);font-size:0.85rem;">{p.rut ?? '—'}</td>
              <td style="color:var(--stone);font-size:0.85rem;">{formatDate(p.created_at)}</td>
              <td>
                <span class={`badge ${p.active ? 'badge-confirmed' : 'badge-cancelled'}`}>
                  {p.active ? 'Activo' : 'Archivado'}
                </span>
              </td>
              <td>
                <a href={`/admin/pacientes/${p.id}`} class="btn btn-outline btn-sm"
                   onclick="event.stopPropagation()">
                  Ver ficha →
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <!-- Total -->
  <p style="margin-top:1rem;font-size:0.8rem;color:var(--stone);">
    {patients?.length ?? 0} paciente{patients?.length !== 1 ? 's' : ''}
  </p>

</AdminLayout>

<!-- Modal nuevo paciente -->
<div id="modal-new-patient" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:100;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:white;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;padding:2rem;border-radius:6px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
      <p style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;">Nuevo paciente</p>
      <button id="close-new-patient" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--stone);">✕</button>
    </div>

    <form method="POST" action="/api/admin/patients" style="display:flex;flex-direction:column;gap:1rem;">
      <input type="hidden" name="action" value="create" />
      <input type="hidden" name="redirect" value="/admin/pacientes?saved=1" />

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.3rem;">Nombre completo *</label>
          <input type="text" name="name" required placeholder="Nombre completo" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Email</label>
          <input type="email" name="email" placeholder="correo@ejemplo.cl" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Teléfono</label>
          <input type="tel" name="phone" placeholder="+56 9 XXXX XXXX" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">RUT</label>
          <input type="text" name="rut" placeholder="12.345.678-9" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Fecha de nacimiento</label>
          <input type="date" name="birthdate" />
        </div>
        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.3rem;">Dirección</label>
          <input type="text" name="address" placeholder="Dirección" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Contacto emergencia</label>
          <input type="text" name="emergency_name" placeholder="Nombre" />
        </div>
        <div>
          <label class="label" style="display:block;margin-bottom:0.3rem;">Tel. emergencia</label>
          <input type="tel" name="emergency_phone" placeholder="+56 9 XXXX XXXX" />
        </div>
        <div style="grid-column:1/-1;">
          <label class="label" style="display:block;margin-bottom:0.3rem;">Notas generales</label>
          <textarea name="notes" rows="3" placeholder="Motivo de consulta inicial, antecedentes..."></textarea>
        </div>
      </div>

      <button type="submit" class="btn btn-dark" style="width:100%;justify-content:center;margin-top:0.5rem;">
        Crear paciente
      </button>
    </form>
  </div>
</div>

<script>
  const modal    = document.getElementById('modal-new-patient');
  const openBtn  = document.getElementById('open-new-patient');
  const closeBtn = document.getElementById('close-new-patient');

  openBtn?.addEventListener('click', () => { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; });
  const close = () => { modal.style.display = 'none'; document.body.style.overflow = ''; };
  closeBtn?.addEventListener('click', close);
  modal?.addEventListener('click', e => { if (e.target === modal) close(); });
</script>
