---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const MONTHS_LONG = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];

// Mes seleccionado (YYYY-MM), por defecto el actual
const now      = new Date();
const curYM    = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
const selYM    = Astro.url.searchParams.get('mes') ?? curYM;
const [selY, selM] = selYM.split('-').map(Number);
const todayStr = now.toISOString().split('T')[0];

// Todas las reservas no canceladas
const { data: all } = await supabase
  .from('bookings')
  .select('amount, status, payment_method, session_type, session_date')
  .neq('status', 'cancelled');
const bookings = all ?? [];

const isConfirmed = (s: string) => s === 'confirmed';

// ── Total por cobrar histórico (pendientes de pago) ────────────────────────
const totalPorCobrar = bookings
  .filter(b => !isConfirmed(b.status) && b.amount)
  .reduce((sum, b) => sum + (b.amount ?? 0), 0);

// ── Reservas del mes seleccionado ──────────────────────────────────────────
const inMonth = bookings.filter(b => {
  const [y, m] = (b.session_date ?? '').split('-').map(Number);
  return y === selY && m === selM;
});

// Pagos confirmados del mes (ingresos)
const pagosMes = inMonth.filter(b => isConfirmed(b.status));
const ingresosMes = pagosMes.reduce((s, b) => s + (b.amount ?? 0), 0);

// Desglose por método de pago
const PM_LABEL: Record<string, string> = { manual: 'Pago en consulta', transferencia: 'Transferencia', flow: 'Flow (Webpay)' };
const byMethod: Record<string, { count: number; total: number }> = {};
pagosMes.forEach(b => {
  const k = b.payment_method ?? 'otro';
  (byMethod[k] ??= { count: 0, total: 0 });
  byMethod[k].count++;
  byMethod[k].total += b.amount ?? 0;
});

// Atenciones del mes por tipo de sesión
const ST_LABEL: Record<string, string> = {
  'online': 'Individual Online', 'presencial': 'Individual Presencial',
  'pareja-online': 'Pareja Online', 'pareja-presencial': 'Pareja Presencial',
};
const byType: Record<string, number> = {};
inMonth.forEach(b => { const k = b.session_type ?? 'otro'; byType[k] = (byType[k] ?? 0) + 1; });
const totalAtenciones = inMonth.length;

// Lista de meses para el selector (12 hacia atrás)
const monthOptions = Array.from({ length: 12 }, (_, i) => {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const ym = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  return { value: ym, label: `${MONTHS_LONG[d.getMonth()].charAt(0).toUpperCase() + MONTHS_LONG[d.getMonth()].slice(1)} ${d.getFullYear()}` };
});

const formatCLP = (n: number) =>
  new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);
---

<AdminLayout title="Finanzas" current="/admin/finanzas" fullHeight={true}>

  <div class="fin-wrap">
    <div class="fin-head">
      <h1>Finanzas</h1>
    </div>

    <div class="fin-scroll">

      <!-- Tarjetas superiores -->
      <div class="fin-top">
        <div class="fin-card">
          <div class="fin-card-label">Ingresos confirmados · {monthOptions.find(m => m.value === selYM)?.label ?? selYM}</div>
          <div class="fin-card-value">{formatCLP(ingresosMes)}</div>
          <div class="fin-card-foot">
            <span class="fin-muted">{pagosMes.length} pago{pagosMes.length !== 1 ? 's' : ''} confirmado{pagosMes.length !== 1 ? 's' : ''}</span>
          </div>
        </div>

        <div class="fin-card fin-card-due">
          <div class="fin-card-label" style="color:#dc2626;">Total por cobrar histórico</div>
          <div class="fin-card-value">{formatCLP(totalPorCobrar)}</div>
          <div class="fin-card-foot">
            <a href="/admin/cobros" class="btn btn-outline btn-sm">Ir a cobrar →</a>
          </div>
        </div>
      </div>

      <!-- Resumen del mes -->
      <div class="fin-section-head">
        <span>Resumen de</span>
        <form method="GET" action="/admin/finanzas" id="mes-form">
          <select name="mes" onchange="document.getElementById('mes-form').submit()">
            {monthOptions.map(m => (
              <option value={m.value} selected={m.value === selYM}>{m.label}</option>
            ))}
          </select>
        </form>
      </div>

      <div class="fin-tabs">
        <button class="fin-tab active" data-tab="pagos">Pagos</button>
        <button class="fin-tab" data-tab="atenciones">Atenciones</button>
      </div>

      <!-- Pagos -->
      <div class="fin-grid" id="tab-pagos">
        <div class="fin-panel">
          <div class="fin-panel-value" style="color:#4f5ce8;">{formatCLP(ingresosMes)}</div>
          <p class="fin-panel-note">Ingresos confirmados del mes</p>
          <div class="fin-breakdown">
            {Object.keys(byMethod).length === 0 ? (
              <p class="fin-muted" style="padding:0.5rem 0;">Sin pagos confirmados este mes.</p>
            ) : Object.entries(byMethod).map(([k, v]) => (
              <div class="fin-break-row">
                <span>{PM_LABEL[k] ?? k} <span class="fin-muted">· {v.count}</span></span>
                <strong>{formatCLP(v.total)}</strong>
              </div>
            ))}
          </div>
        </div>

        <div class="fin-panel">
          <div class="fin-panel-label">Pendiente de cobro este mes</div>
          <div class="fin-panel-value">
            {formatCLP(inMonth.filter(b => !isConfirmed(b.status)).reduce((s, b) => s + (b.amount ?? 0), 0))}
          </div>
          <p class="fin-panel-note">{inMonth.filter(b => !isConfirmed(b.status)).length} reserva(s) sin pago confirmado</p>
        </div>
      </div>

      <!-- Atenciones -->
      <div class="fin-grid" id="tab-atenciones" style="display:none;">
        <div class="fin-panel">
          <div class="fin-panel-value">{totalAtenciones}</div>
          <p class="fin-panel-note">Atenciones agendadas del mes</p>
          <div class="fin-breakdown">
            {totalAtenciones === 0 ? (
              <p class="fin-muted" style="padding:0.5rem 0;">Sin atenciones este mes.</p>
            ) : Object.entries(byType).map(([k, n]) => (
              <div class="fin-break-row">
                <span>{ST_LABEL[k] ?? k}</span>
                <strong>{n}</strong>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Detalle de transacciones -->
      <div class="fin-section-head" style="margin-top:1.5rem;"><span>Detalle de transacciones</span></div>
      <div class="fin-table-wrap">
        {inMonth.length === 0 ? (
          <p class="fin-muted" style="padding:1.5rem;text-align:center;">Sin transacciones este mes.</p>
        ) : (
          <table class="fin-table">
            <thead><tr><th>Fecha</th><th>Tipo</th><th>Método</th><th>Estado</th><th style="text-align:right;">Monto</th></tr></thead>
            <tbody>
              {inMonth.sort((a, b) => (b.session_date ?? '').localeCompare(a.session_date ?? '')).map(b => (
                <tr>
                  <td class="fin-muted">{b.session_date}</td>
                  <td>{ST_LABEL[b.session_type] ?? b.session_type}</td>
                  <td class="fin-muted">{PM_LABEL[b.payment_method] ?? b.payment_method ?? '—'}</td>
                  <td>
                    <span class={`fin-badge ${isConfirmed(b.status) ? 'ok' : 'due'}`}>
                      {isConfirmed(b.status) ? 'Pagado' : 'Por pagar'}
                    </span>
                  </td>
                  <td style="text-align:right;font-weight:600;">{formatCLP(b.amount ?? 0)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>

    </div>
  </div>

</AdminLayout>

<style>
.fin-wrap { display: flex; flex-direction: column; height: 100vh; overflow: hidden; background: white; }
.fin-head { padding: 1.25rem 1.5rem 0.5rem; }
.fin-head h1 { font-size: 1.6rem; font-weight: 700; color: #111827; }
.fin-scroll { flex: 1; min-height: 0; overflow-y: auto; padding: 0.5rem 1.5rem 2rem; }

.fin-top { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
@media (max-width: 720px) { .fin-top { grid-template-columns: 1fr; } }
.fin-card { border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.25rem 1.5rem; }
.fin-card-label { font-size: 0.85rem; color: #6b7280; margin-bottom: 0.5rem; }
.fin-card-value { font-size: 2rem; font-weight: 700; color: #111827; line-height: 1; }
.fin-card-foot { margin-top: 1rem; }
.fin-muted { color: #9ca3af; }

.fin-section-head { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.fin-section-head span { font-size: 1.05rem; font-weight: 600; color: #111827; }
.fin-section-head select { width: auto; min-width: 160px; }

.fin-tabs { display: inline-flex; background: #f3f4f6; border-radius: 9px; padding: 3px; margin-bottom: 1rem; }
.fin-tab { padding: 0.45rem 1.5rem; font-size: 0.85rem; font-weight: 500; color: #6b7280; background: none; border: none; border-radius: 7px; cursor: pointer; }
.fin-tab.active { background: white; color: #111827; font-weight: 600; box-shadow: 0 1px 2px rgba(0,0,0,.08); }

.fin-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
@media (max-width: 720px) { .fin-grid { grid-template-columns: 1fr; } }
.fin-panel { border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem; }
.fin-panel-label { font-size: 0.8rem; color: #6b7280; margin-bottom: 0.5rem; }
.fin-panel-value { font-size: 1.75rem; font-weight: 700; color: #111827; line-height: 1; }
.fin-panel-note { font-size: 0.8rem; color: #6b7280; margin-top: 0.4rem; }
.fin-breakdown { margin-top: 1rem; border-top: 1px solid #f3f4f6; padding-top: 0.75rem; }
.fin-break-row { display: flex; justify-content: space-between; padding: 0.4rem 0; font-size: 0.875rem; color: #374151; }

.fin-table-wrap { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
.fin-table { width: 100%; border-collapse: collapse; }
.fin-table th { text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; color: #6b7280; font-weight: 600; padding: 0.7rem 1rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; }
.fin-table td { padding: 0.75rem 1rem; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem; }
.fin-table tr:last-child td { border-bottom: none; }
.fin-badge { display: inline-flex; padding: 2px 9px; border-radius: 99px; font-size: 0.72rem; font-weight: 600; }
.fin-badge.ok  { background: #f0fdf4; color: #15803d; }
.fin-badge.due { background: #fef2f2; color: #dc2626; }
</style>

<script>
  document.querySelectorAll('.fin-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.fin-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const which = tab.dataset.tab;
      document.getElementById('tab-pagos').style.display      = which === 'pagos' ? 'grid' : 'none';
      document.getElementById('tab-atenciones').style.display = which === 'atenciones' ? 'grid' : 'none';
    });
  });
</script>
