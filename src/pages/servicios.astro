---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero   from '../components/sections/PageHero.astro';
import { services } from '../data/services';
---

<BaseLayout title="Servicios" description="Servicios de psicología clínica: adultos, parejas, trauma y personas altamente sensibles.">

  <PageHero label="¿En qué puedo ayudarte?" title="Servicios" />

  <section class="py-section bg-sand">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {services.map((service, i) => (
          <div class="relative overflow-hidden rounded-[10px] group min-h-[420px] flex flex-col justify-end">

            <!-- Imagen de fondo -->
            {service.image && (
              <img
                src={service.image}
                alt={service.title}
                class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700"
              />
            )}

            <!-- Degradado inferior para legibilidad -->
            <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/40 to-transparent"></div>

            <!-- Contenido sobre la imagen -->
            <div class="relative z-10 p-8 md:p-10">
              <p class="label text-white/50 mb-3">0{i + 1}</p>
              <h2 class="font-heading font-light text-3xl md:text-4xl text-white leading-tight mb-3">
                {service.title}
              </h2>
              <p class="font-body text-sm text-white/70 font-light leading-relaxed mb-6 max-w-sm">
                {service.description}
              </p>
              <div class="flex items-center justify-between pt-5 border-t border-white/20">
                <div>
                  <p class="label text-white/40 mb-0.5">Duración</p>
                  <p class="font-heading font-light text-lg text-white">{service.duration}</p>
                </div>
                <a href="/agenda"
                  class="font-body text-xs tracking-widest uppercase py-2.5 px-5 border border-white/40 text-white hover:bg-white hover:text-ink transition-all duration-200">
                  Reservar
                </a>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-20 bg-ink text-center">
    <div class="container-site max-w-xl">
      <p class="label text-sand/40 mb-4">¿No sabes por dónde empezar?</p>
      <div class="divider-center bg-sand/20 mb-8"></div>
      <h2 class="font-heading font-light text-3xl md:text-4xl text-sand mb-6">
        Escríbeme y lo<br />descubrimos juntos.
      </h2>
      <a href="/contacto" class="btn bg-sand text-ink hover:bg-gold hover:text-white text-[10px] tracking-widest2 uppercase py-3.5 px-8 transition-all duration-300">
        Contactar a Valentina
      </a>
    </div>
  </section>

</BaseLayout>
