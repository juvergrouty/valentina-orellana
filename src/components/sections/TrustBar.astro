---
import Icon from '../ui/Icon.astro';

const items = [
  { icon: 'shield',   title: 'Espacio confidencial',   sub: 'y seguro' },
  { icon: 'users',    title: 'Acompañamiento profesional', sub: 'y cercano' },
  { icon: 'leaf',     title: 'Enfoque basado',          sub: 'en evidencia' },
  { icon: 'building', title: 'Sesiones presenciales',   sub: 'y online' },
];
---

<section class="bg-warm border-b border-dust">
  <div class="container-site">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-dust">
      {items.map((item) => (
        <div class="flex flex-col items-center text-center py-14 px-4 gap-3">
          <div class="text-forest/70">
            <Icon name={item.icon} size={22} />
          </div>
          <div>
            <p class="body-text font-medium text-ink leading-snug">{item.title}</p>
            <p class="body-sm">{item.sub}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
