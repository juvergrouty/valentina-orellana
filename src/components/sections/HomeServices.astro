---
import { supabase } from '../../lib/supabase';

const SELECT = 'id, name, description, modality, location, image_url, type, price, duration_min';

// 1º: servicios marcados para el inicio (⭐). 2º: si no hay, los visibles reales.
let { data: dbServices } = await supabase
  .from('services_catalog').select(SELECT)
  .eq('show_home', true).eq('visible', true)
  .order('sort_order').limit(10);

if (!dbServices || dbServices.length === 0) {
  const { data: visibles } = await supabase
    .from('services_catalog').select(SELECT)
    .eq('visible', true)
    .order('sort_order').limit(6);
  dbServices = visibles ?? [];
}

const formatCLP = (n: number) =>
  new Intl.NumberFormat('es-CL', { style:'currency', currency:'CLP', maximumFractionDigits:0 }).format(n);

const cards = (dbServices ?? []).map(s => ({
  ...s,
  href:       `/agenda?servicio=${s.id}`,
  badge:      s.modality === 'online' ? 'Online' : s.modality === 'presencial' ? 'Presencial' : 'Online · Presencial',
  priceLabel: formatCLP(s.price),
}));
---

{cards.length > 0 && (
<section class="py-section bg-sand">
  <div class="container-site">

    <!-- Encabezado + controles en la misma fila -->
    <div class="flex items-end justify-between mb-10 gap-4">
      <div>
        <p class="label text-stone mb-3">¿En qué puedo ayudarte?</p>
        <h2 class="section-title">Terapia para crecer,<br class="hidden md:block" /> sanar y avanzar.</h2>
      </div>
      <!-- Flechas de navegación -->
      <div class="hidden md:flex gap-2 flex-shrink-0">
        <button id="svc-prev"
          class="w-10 h-10 rounded-full border border-dust flex items-center justify-center text-stone hover:border-ink hover:text-ink transition-all duration-200">
          ‹
        </button>
        <button id="svc-next"
          class="w-10 h-10 rounded-full border border-dust flex items-center justify-center text-stone hover:border-ink hover:text-ink transition-all duration-200">
          ›
        </button>
      </div>
    </div>

    <p class="body-text max-w-xl mb-10 md:hidden">
      Acompañamiento psicológico para adultos y parejas que desean comprenderse,
      mejorar su bienestar y construir relaciones más conscientes.
    </p>

  </div>

  <!-- Carrusel contenido — mismo padding que container-site en ambos lados -->
  <div class="px-6 md:px-12 lg:px-20 xl:px-[max(5rem,calc((100vw-1600px)/2+5rem))]">
    <div id="svc-track"
      class="flex gap-5 overflow-x-auto pb-4"
      style="scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;cursor:grab;">

      {cards.map(card => (
        <div class="flex-shrink-0 w-[80vw] sm:w-[calc(50%-10px)] lg:w-[calc(33.333%-13.4px)] bg-white border border-dust rounded-[10px] overflow-hidden group hover:shadow-lg transition-all duration-300"
             style="scroll-snap-align:start;scroll-snap-stop:always;">

          <!-- Imagen -->
          <div class="relative h-[340px] overflow-hidden">
            <img
              src={card.image_url ?? '/images/consultorio-individual.jpg'}
              alt={card.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/40 to-transparent"></div>
            <span class="absolute top-3 left-3 text-xs font-body font-medium px-3 py-1 rounded-full bg-white/90 text-ink">
              {card.badge}
            </span>
          </div>

          <!-- Contenido -->
          <div class="p-5 flex flex-col" style="min-height:180px;">
            <h3 class="font-heading font-semibold text-lg text-ink leading-tight mb-1">{card.name}</h3>
            {card.location && (
              <p class="font-body text-xs text-stone mb-2">📍 {card.location}</p>
            )}
            <p class="font-body text-sm text-stone font-light leading-relaxed mb-4 flex-1 line-clamp-3">{card.description}</p>

            <div class="flex items-center justify-between pt-3 border-t border-dust">
              <div>
                <p class="font-heading font-semibold text-base text-ink leading-none">{card.priceLabel}</p>
                <p class="font-body text-xs text-stone mt-0.5">{card.duration_min} minutos</p>
              </div>
              <a href={card.href}
                class="font-body text-xs tracking-widest uppercase px-4 py-2 border border-forest text-forest hover:bg-forest hover:text-white transition-all duration-200 rounded-[4px]">
                Reservar
              </a>
            </div>
          </div>

        </div>
      ))}

    </div>
  </div>

  <!-- Dots -->
  <div id="svc-dots" class="flex justify-center gap-2 mt-5 container-site"></div>

</section>
)}

<script>
(function() {
  const track = document.getElementById('svc-track');
  const prev  = document.getElementById('svc-prev');
  const next  = document.getElementById('svc-next');
  const dots  = document.getElementById('svc-dots');

  if (!track) return;

  const cardW = () => {
    const c = track.querySelector('.flex-shrink-0') as HTMLElement;
    if (!c) return 320;
    // gap-5 = 20px; usar offsetWidth del card real para snap exacto
    const gap = parseInt(getComputedStyle(track).gap) || 20;
    return c.offsetWidth + gap;
  };

  // Flechas
  prev?.addEventListener('click', () => track.scrollBy({ left: -cardW(), behavior: 'smooth' }));
  next?.addEventListener('click', () => track.scrollBy({ left:  cardW(), behavior: 'smooth' }));

  // Drag to scroll
  let dragging = false, startX = 0, scrollLeft = 0;
  track.addEventListener('mousedown',  e => { dragging = true; startX = e.pageX; scrollLeft = track.scrollLeft; track.style.cursor = 'grabbing'; });
  track.addEventListener('mouseup',    () => { dragging = false; track.style.cursor = 'grab'; });
  track.addEventListener('mouseleave', () => { dragging = false; track.style.cursor = 'grab'; });
  track.addEventListener('mousemove',  e => { if (!dragging) return; e.preventDefault(); track.scrollLeft = scrollLeft - (e.pageX - startX); });

  // Dots
  const cards = track.querySelectorAll('.flex-shrink-0:not(:last-child)');
  cards.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.setAttribute('aria-label', `Ir al servicio ${i+1}`);
    dot.style.cssText = `width:7px;height:7px;border-radius:50%;border:none;cursor:pointer;transition:all .2s;background:${i===0?'var(--forest)':'var(--dust)'}`;
    dot.addEventListener('click', () => track.scrollTo({ left: i * cardW(), behavior: 'smooth' }));
    dots?.appendChild(dot);
  });

  // Actualizar dots y flechas en scroll
  track.addEventListener('scroll', () => {
    const idx = Math.round(track.scrollLeft / cardW());
    dots?.querySelectorAll('button').forEach((d, i) => {
      (d as HTMLElement).style.background = i === idx ? 'var(--forest)' : 'var(--dust)';
      (d as HTMLElement).style.transform  = i === idx ? 'scale(1.3)' : 'scale(1)';
    });
    if (prev) (prev as HTMLButtonElement).style.opacity = track.scrollLeft < 10 ? '0.3' : '1';
    if (next) (next as HTMLButtonElement).style.opacity = track.scrollLeft + track.clientWidth >= track.scrollWidth - 10 ? '0.3' : '1';
  }, { passive: true });

  // Ocultar scrollbar CSS
  const style = document.createElement('style');
  style.textContent = '#svc-track::-webkit-scrollbar { display:none; }';
  document.head.appendChild(style);
})();
</script>
