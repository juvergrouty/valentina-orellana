---
import Icon from '../ui/Icon.astro';
import { supabase } from '../../lib/supabase';

// Intentar cargar servicios de la BD con show_home=true
const { data: dbServices } = await supabase
  .from('services_catalog')
  .select('id, name, description, modality, location, image_url, type')
  .eq('show_home', true)
  .eq('visible', true)
  .order('sort_order')
  .limit(6);

// Fallback a los 2 servicios estáticos si la tabla está vacía
const fallbackCards = [
  {
    id: 'individual',
    icon: 'brain',
    name: 'Terapia Individual',
    description: 'Un espacio para ti. Para entender lo que sientes, soltar lo que te pesa y reconectar contigo.',
    href: '/servicios?grupo=individual',
    image: '/images/consultorio-individual.jpg',
  },
  {
    id: 'pareja',
    icon: 'users',
    name: 'Terapia de Pareja',
    description: 'Mejoren su comunicación, fortalezcan su vínculo y construyan una relación más sana y consciente.',
    href: '/servicios?grupo=pareja',
    image: '/images/consultorio-pareja.jpg',
  },
];

const useDB = dbServices && dbServices.length > 0;

const cards = useDB
  ? dbServices.map(s => ({
      id:          s.id,
      icon:        s.type === 'pareja' ? 'users' : 'brain',
      name:        s.name,
      description: s.description ?? '',
      href:        `/agenda?grupo=${s.type === 'pareja' ? 'pareja' : 'individual'}`,
      image:       s.image_url ?? '/images/consultorio-individual.jpg',
    }))
  : fallbackCards;
---

<section class="py-section bg-sand">
  <div class="container-site">

    <!-- Encabezado -->
    <div class="text-center mb-14">
      <p class="label text-stone mb-4">¿En qué puedo ayudarte?</p>
      <h2 class="section-title mb-5">Terapia para crecer, sanar y avanzar.</h2>
      <p class="body-text max-w-xl mx-auto">
        Acompañamiento psicológico para adultos y parejas que desean comprenderse,
        mejorar su bienestar y construir relaciones más conscientes.
      </p>
    </div>

    <!-- Carrusel / Grid de servicios -->
    {cards.length <= 2 ? (
      <!-- Hasta 2: layout horizontal dentro de cada card -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {cards.map(card => (
          <div class="bg-white border border-dust rounded-[10px] overflow-hidden group hover:shadow-md transition-shadow duration-300 flex flex-row" style="min-height: 300px;">
            <div class="flex flex-col justify-between p-7 flex-1 min-w-0">
              <div>
                <div class="icon-circle mb-4">
                  <Icon name={card.icon} size={20} />
                </div>
                <h3 class="font-heading font-semibold text-xl text-ink mb-3 leading-tight">{card.name}</h3>
                <p class="body-sm leading-relaxed">{card.description}</p>
              </div>
              <a href={card.href}
                 class="font-body text-sm text-forest tracking-wide flex items-center gap-2 hover:gap-3 transition-all duration-200 w-fit mt-6">
                Conocer más
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
            <div class="relative w-[42%] flex-shrink-0 overflow-hidden">
              <div class="absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-white to-transparent z-10"></div>
              <img src={card.image} alt={card.name}
                class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700" />
            </div>
          </div>
        ))}
      </div>
    ) : (
      <!-- 3 o más: carrusel horizontal scrollable -->
      <div style="overflow-x:auto;padding-bottom:0.5rem;-webkit-overflow-scrolling:touch;scrollbar-width:thin;">
        <div style={`display:flex;gap:1.25rem;width:max-content;padding:0.25rem 0.1rem;`}>
          {cards.map(card => (
            <div class="bg-white border border-dust rounded-[10px] overflow-hidden group hover:shadow-md transition-shadow duration-300 flex flex-col"
                 style="width:300px;flex-shrink:0;">
              <div class="relative w-full overflow-hidden" style="height:180px;">
                <img src={card.image} alt={card.name}
                  class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-ink/40 to-transparent"></div>
              </div>
              <div class="p-5 flex flex-col flex-1">
                <h3 class="font-heading font-semibold text-lg text-ink mb-2 leading-tight">{card.name}</h3>
                <p class="body-sm leading-relaxed mb-4 flex-1 line-clamp-3">{card.description}</p>
                <a href={card.href}
                   class="font-body text-sm text-forest tracking-wide flex items-center gap-1.5 hover:gap-2.5 transition-all duration-200 w-fit mt-auto">
                  Reservar →
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>
</section>
