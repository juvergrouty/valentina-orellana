---
import { pricingPlans } from '../../data/services';

const formatCLP = (n: number) =>
  new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);
---

<section class="py-section bg-warm texture-dots">
  <div class="container-site">

    <div class="text-center mb-16">
      <p class="label text-stone mb-4">Precios</p>
      <div class="divider-center mb-6"></div>
      <h2 class="section-title">Inversión en tu bienestar</h2>
      <p class="body-text max-w-md mx-auto mt-5">
        Transparencia desde el primer momento. Pago seguro con tarjeta o transferencia.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-dust">
      {pricingPlans.map((plan) => (
        <div class={`flex flex-col p-10 md:p-12 transition-colors duration-300 relative
          ${plan.highlighted ? 'bg-ink text-sand' : 'bg-white hover:bg-sand'}`}>

          {plan.highlighted && (
            <span class="label text-sand/50 mb-4 block">Más solicitado</span>
          )}

          <p class={`font-heading font-light text-2xl mb-2 ${plan.highlighted ? 'text-sand' : 'text-ink'}`}>
            {plan.title}
          </p>

          <p class={`font-heading font-light mb-1 ${plan.highlighted ? 'text-sand' : 'text-ink'}`}
             style="font-size: clamp(2rem, 4vw, 3rem);">
            {formatCLP(plan.price)}
          </p>

          <p class={`font-body text-xs mb-8 ${plan.highlighted ? 'text-sand/50' : 'text-stone'}`}>
            {plan.duration} · {plan.modality}
          </p>

          <div class={`h-px mb-8 ${plan.highlighted ? 'bg-sand/20' : 'bg-dust'}`}></div>

          <ul class="space-y-3 flex-1 mb-10">
            {plan.features.map((f) => (
              <li class={`font-body text-sm font-light flex items-start gap-3 ${plan.highlighted ? 'text-sand/70' : 'text-stone'}`}>
                <span class={`mt-1 text-xs ${plan.highlighted ? 'text-gold' : 'text-gold'}`}>—</span>
                {f}
              </li>
            ))}
          </ul>

          <a href="/agenda"
            class={`text-center text-[10px] tracking-widest2 uppercase py-3.5 px-8 transition-all duration-300 inline-block
              ${plan.highlighted
                ? 'bg-sand text-ink hover:bg-forest hover:text-white'
                : 'border border-forest text-forest hover:bg-forest hover:text-white'}`}>
            Reservar
          </a>
        </div>
      ))}
    </div>

    <p class="text-center label text-stone mt-8">
      Pago seguro con MercadoPago · Tarjeta · Transferencia bancaria
    </p>

  </div>
</section>
