---
import { getCachedReviews } from '../../lib/googleReviews';

const cache   = await getCachedReviews();
const reviews = (cache?.reviews ?? []).filter(r => r.text).slice(0, 5);
const rating  = cache?.rating ?? 5.0;
const total   = cache?.total ?? null;
---

<section class="relative overflow-hidden bg-sand min-h-[680px] sm:min-h-0">

  <!-- Imagen hero: en mobile absolute+cover para llenar min-h, en sm+ fluye con tamaño natural -->
  <img
    src="/images/hero-home.webp"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover object-[80%_20%] block sm:static sm:inset-auto sm:h-auto sm:object-[unset]"
    width="1920"
    height="900"
  />

  <!-- Degradado: cubre todo el ancho en mobile (texto sobre imagen), solo lado izq en desktop -->
  <div class="absolute inset-y-0 left-0 w-full sm:w-[55%] bg-gradient-to-r from-sand/95 via-sand/85 to-sand/50 sm:via-sand/70 sm:to-transparent"></div>

  <!-- Texto superpuesto -->
  <div class="absolute inset-0 flex items-start pt-14 sm:pt-0 sm:items-center">
    <div class="container-site w-full">
      <div class="max-w-lg">

        <p class="label text-stone mb-6">Psicóloga Clínica · Santiago, Chile</p>

        <h1 class="display-title leading-tight mb-6">
          Un espacio seguro donde puedes ser tú, sin máscaras.
        </h1>

        <p class="body-lead mb-6 sm:mb-10">
          Terapia para adultos y parejas que buscan bienestar emocional,
          claridad y relaciones más auténticas.
        </p>

        <div class="flex flex-wrap items-center gap-4 mb-8 sm:mb-10">
          <a href="/agenda" class="btn-dark py-3.5 px-7">Agendar sesión</a>
          <a href="/sobre-mi"
             class="font-body text-sm text-ink tracking-wide flex items-center gap-2 hover:text-forest transition-colors duration-200">
            Conocer más
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Social proof / carrusel de reseñas -->
        {reviews.length > 0 ? (
          <div class="max-w-md">
            <div class="flex items-center gap-2 mb-2">
              <div class="flex gap-0.5">
                {Array.from({length:5}).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#F5A623" stroke="none">
                    <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
                  </svg>
                ))}
              </div>
              <p class="font-body text-sm text-stone leading-snug">
                <span class="font-medium text-ink">{rating.toFixed(1)} en Google</span>{total ? ` · ${total} reseñas` : ''}
              </p>
            </div>

            <div id="hero-reviews" class="relative min-h-[150px] sm:min-h-[88px]">
              {reviews.map((r, i) => (
                <blockquote
                  class="hero-review font-body text-sm text-stone leading-relaxed"
                  data-idx={i}
                  style={`transition:opacity .6s ease; position:${i===0?'relative':'absolute'}; inset:0; opacity:${i===0?1:0}; pointer-events:${i===0?'auto':'none'};`}
                >
                  <span class="italic">"{r.text.length > 150 ? r.text.slice(0,150).trim() + '… ' : r.text}"</span>
                  {r.text.length > 150 && (
                    <button type="button" class="hero-review-more not-italic"
                      data-full={r.text} data-author={r.author} data-rating={String(r.rating ?? 5)}
                      style="color:#576352;font-weight:500;text-decoration:underline;">leer más</button>
                  )}
                  <span class="block mt-1 not-italic font-medium text-ink">— {r.author}</span>
                </blockquote>
              ))}
            </div>

            {reviews.length > 1 && (
              <div id="hero-dots" class="flex gap-1.5 mt-3">
                {reviews.map((_, i) => (
                  <button type="button" class="hero-dot" data-idx={i} aria-label={`Reseña ${i+1}`}
                    style={`width:7px;height:7px;border-radius:9999px;border:none;padding:0;cursor:pointer;transition:background .3s,width .3s;background:${i===0?'#576352':'#D8D2C8'};${i===0?'width:16px;':''}`}></button>
                ))}
              </div>
            )}
          </div>
        ) : (
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#576352" stroke-width="1.75" class="flex-shrink-0">
              <path d="M9 12l2 2 4-4"/><path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9c1.5 0 2.9.37 4.15 1.02"/>
            </svg>
            <p class="font-body text-sm text-stone leading-snug">
              <span class="font-medium text-ink">Psicóloga Clínica</span> · Reg. Superintendencia de Salud N° 360070
            </p>
          </div>
        )}

      </div>
    </div>
  </div>

  <!-- Modal reseña completa -->
  <div id="review-modal" style="display:none;position:fixed;inset:0;background:rgba(26,26,24,.55);z-index:200;align-items:center;justify-content:center;padding:1rem;">
    <div style="background:white;max-width:480px;width:100%;border-radius:10px;padding:1.75rem;position:relative;max-height:85vh;overflow-y:auto;">
      <button id="review-modal-close" aria-label="Cerrar"
        style="position:absolute;top:0.6rem;right:0.85rem;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#9B9485;line-height:1;">✕</button>
      <div id="review-modal-stars" style="display:flex;gap:2px;margin-bottom:0.85rem;"></div>
      <p id="review-modal-text" class="font-body" style="font-size:0.95rem;line-height:1.7;color:#374151;"></p>
      <p id="review-modal-author" class="font-body" style="margin-top:0.9rem;font-weight:600;color:#1A1A18;"></p>
      <p style="margin-top:0.2rem;font-size:0.72rem;color:#9B9485;">Reseña de Google</p>
    </div>
  </div>

  <script>
    (() => {
      const wrap = document.getElementById('hero-reviews');
      if (!wrap) return;
      const items = Array.from(wrap.querySelectorAll('.hero-review'));
      const dots  = Array.from(document.querySelectorAll('#hero-dots .hero-dot'));

      let i = 0, timer = null;
      const show = (n) => {
        items[i].style.opacity = '0';
        items[i].style.pointerEvents = 'none';
        if (dots[i]) { dots[i].style.background = '#D8D2C8'; dots[i].style.width = '7px'; }
        i = (n + items.length) % items.length;
        items[i].style.opacity = '1';
        items[i].style.pointerEvents = 'auto';
        if (dots[i]) { dots[i].style.background = '#576352'; dots[i].style.width = '16px'; }
      };
      const start = () => { if (items.length > 1 && !timer) timer = setInterval(() => show(i + 1), 5000); };
      const stop  = () => { if (timer) { clearInterval(timer); timer = null; } };

      // ── Modal "leer más" ──
      const modal   = document.getElementById('review-modal');
      const mText   = document.getElementById('review-modal-text');
      const mAuthor = document.getElementById('review-modal-author');
      const mStars  = document.getElementById('review-modal-stars');
      const starSvg = (n) => Array.from({length:5}, (_, k) =>
        `<svg width="15" height="15" viewBox="0 0 24 24" fill="${k < Math.round(n) ? '#F5A623' : 'none'}" stroke="#F5A623" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
      ).join('');
      const openModal = (full, author, rating) => {
        mText.textContent   = '"' + full + '"';
        mAuthor.textContent = '— ' + author;
        mStars.innerHTML    = starSvg(Number(rating) || 5);
        modal.style.display = 'flex';
        stop();
      };
      const closeModal = () => { modal.style.display = 'none'; start(); };
      document.querySelectorAll('.hero-review-more').forEach(b => b.addEventListener('click', (e) => {
        e.stopPropagation();
        openModal(b.dataset.full, b.dataset.author, b.dataset.rating);
      }));
      document.getElementById('review-modal-close')?.addEventListener('click', closeModal);
      modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

      // ── Carrusel (solo si hay 2+) ──
      if (items.length > 1) {
        dots.forEach((d, idx) => d.addEventListener('click', () => { stop(); show(idx); start(); }));
        wrap.addEventListener('mouseenter', stop);
        wrap.addEventListener('mouseleave', start);
        start();
      }
    })();
  </script>

</section>
