---
---

<section class="bg-sand relative overflow-hidden min-h-[calc(100vh-73px)]">

  <!-- Imagen de fondo — lado derecho en desktop -->
  <div class="absolute top-0 right-0 w-full h-full lg:w-[52%] xl:w-[50%] lg:rounded-l-[10px] overflow-hidden">
    <img
      src="/images/valentina-retrato.jpg"
      alt="Ps. Valentina Orellana"
      class="w-full h-full object-cover object-top"
      id="hero-img"
      onerror="this.style.display='none'; document.getElementById('hero-placeholder').style.display='flex';"
    />
    <!-- Placeholder si no hay imagen -->
    <div id="hero-placeholder" class="absolute inset-0 hidden items-center justify-center bg-warm flex-col gap-3">
      <div class="w-14 h-px bg-dust"></div>
      <p class="label text-dust">Fotografía · 900 × 1100</p>
      <div class="w-14 h-px bg-dust"></div>
    </div>
    <!-- Gradiente sutil en el lado izquierdo para blend en desktop -->
    <div class="absolute inset-y-0 left-0 w-20 bg-gradient-to-r from-sand from-0% to-transparent hidden lg:block"></div>
    <!-- Overlay suave en mobile para leer el texto encima -->
    <div class="absolute inset-0 bg-sand/70 lg:hidden"></div>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 container-site min-h-[calc(100vh-73px)] flex items-center">
    <div class="w-full lg:w-[52%] xl:w-[50%] py-20 lg:py-28">

      <p class="label text-stone mb-6">Psicóloga Clínica · Santiago, Chile</p>

      <h1 class="display-title mb-6">
        Un espacio seguro donde puedes ser tú, sin máscaras.
      </h1>

      <p class="body-lead mb-10 max-w-md">
        Terapia para adultos y parejas que buscan bienestar emocional,
        claridad y relaciones más auténticas.
      </p>

      <div class="flex flex-wrap items-center gap-4 mb-14">
        <a href="/agenda" class="btn-dark py-3.5 px-7 text-[11px]">
          Agendar sesión
        </a>
        <a href="/sobre-mi"
           class="font-body text-[11px] text-ink tracking-wide flex items-center gap-2 hover:text-forest transition-colors duration-200">
          Conocer más
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <!-- Social proof -->
      <div class="flex items-center gap-4">
        <!-- Avatares iniciales -->
        <div class="flex -space-x-2">
          {['C', 'D', 'M', 'A', 'P'].map((initial, i) => (
            <div class={`w-9 h-9 rounded-full border-2 border-sand flex items-center justify-center flex-shrink-0
              ${['bg-warm', 'bg-dust/60', 'bg-warm', 'bg-dust/60', 'bg-warm'][i]}`}>
              <span class="font-body text-[10px] font-medium text-stone">{initial}</span>
            </div>
          ))}
        </div>
        <div>
          <!-- Estrellas -->
          <div class="flex gap-0.5 mb-0.5">
            {Array.from({length: 5}).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#F5A623" stroke="none">
                <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
              </svg>
            ))}
          </div>
          <p class="body-sm leading-snug">
            <span class="font-medium text-ink">5.0 en Google</span> · Basado en 20+ reseñas reales
          </p>
        </div>
      </div>

    </div>
  </div>

</section>
