---
interface Props {
  label: string;
  title: string;
  description?: string;
  image?: string;  // imagen personalizada, por defecto hero-paginas.jpg
}
const { label, title, description, image = '/images/hero-paginas.jpg' } = Astro.props;
---

<section class="relative overflow-hidden min-h-[380px] md:min-h-[420px] flex items-end border-b border-dust">

  <!-- Imagen de fondo: object-[50%_25%] muestra la parte superior de imágenes panorámicas -->
  <img
    src={image}
    alt=""
    class="absolute inset-0 w-full h-full object-cover object-[50%_25%]"
    aria-hidden="true"
  />

  <!-- Degradado sobre la imagen — más oscuro abajo para que el texto resalte -->
  <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/30 to-ink/10"></div>

  <!-- Contenido -->
  <div class="relative z-10 container-site py-14 md:py-20 w-full">
    <p class="label text-white/60 mb-3">{label}</p>
    <div class="w-10 h-0.5 bg-white/30 mb-5"></div>
    <h1 class="font-heading font-semibold text-display text-white leading-tight"
        style="font-size: clamp(2rem, 5vw, 3.8rem); letter-spacing: -0.02em;">
      {title}
    </h1>
    {description && (
      <p class="font-body text-white/75 font-light text-lg mt-4 max-w-lg leading-relaxed">{description}</p>
    )}
  </div>

</section>
