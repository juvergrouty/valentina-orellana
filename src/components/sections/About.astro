---
import Icon from '../ui/Icon.astro';
---

<section class="bg-white overflow-hidden">

  <!-- MOBILE: layout vertical apilado -->
  <div class="flex flex-col md:hidden">
    <!-- Texto mobile -->
    <div class="px-6 pt-14 pb-8">
      <p class="label text-stone mb-2">Sobre mí</p>
      <div class="w-7 h-0.5 bg-forest/30 mb-4"></div>
      <p class="body-sm mb-4">
        Soy Valentina Orellana, psicóloga clínica con experiencia en terapia para adultos
        y parejas. Mi enfoque es cálido, cercano y basado en evidencia.
      </p>
      <a href="/sobre-mi" class="font-body text-sm text-stone flex items-center gap-2 hover:text-forest transition-colors w-fit">
        Conocer más sobre mí
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>
    <!-- Stats mobile: 3 columnas -->
    <div class="grid grid-cols-3 border-t border-dust">
      {[
        { icon: 'users',   value: '+15 años',   label: 'acompañando a personas y parejas' },
        { icon: 'shield',  value: '100%',       label: 'comprometida con cada proceso' },
        { icon: 'map-pin', value: 'Las Condes', label: 'y atención online en todo Chile' },
      ].map(({ icon, value, label }, i) => (
        <div class={`flex flex-col items-center text-center px-3 py-6 gap-1 ${i > 0 ? 'border-l border-dust' : ''}`}>
          <div class="text-stone/40 mb-1"><Icon name={icon} size={36} /></div>
          <p class="font-heading font-semibold text-base text-ink leading-none mb-0.5">{value}</p>
          <p class="text-xs text-stone leading-snug">{label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- DESKTOP: layout horizontal -->
  <div class="hidden md:flex items-stretch container-site" style="min-height:240px;">

    <!-- Contenido -->
    <div class="flex flex-1 items-stretch">

      <!-- Texto -->
      <div class="flex flex-col justify-center py-8 px-8 lg:px-10 flex-shrink-0" style="width:386px;">
        <p class="label text-stone mb-2">Sobre mí</p>
        <div class="w-7 h-0.5 bg-forest/30 mb-4"></div>
        <p class="body-sm mb-4">
          Soy Valentina Orellana, psicóloga clínica con experiencia en terapia para adultos
          y parejas. Mi enfoque es cálido, cercano y basado en evidencia.
        </p>
        <a href="/sobre-mi" class="font-body text-sm text-stone flex items-center gap-2 hover:text-forest hover:gap-3 transition-all duration-200 w-fit">
          Conocer más sobre mí
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div class="flex flex-1 items-stretch pr-8 lg:pr-16">
        {[
          { icon: 'users',   value: '+15 años',   label: 'acompañando a personas y parejas' },
          { icon: 'shield',  value: '100%',       label: 'comprometida con cada proceso' },
          { icon: 'map-pin', value: 'Las Condes', label: 'y atención online en todo Chile' },
        ].map(({ icon, value, label }, i) => (
          <>
            {i > 0 && (
              <div class="flex items-center">
                <div class="w-px bg-dust" style="height:48px;"></div>
              </div>
            )}
            <div class="flex flex-col items-center justify-center text-center px-4 py-8 gap-1.5 flex-1">
              <div class="text-stone/40 mb-2"><Icon name={icon} size={44} /></div>
              <p class="font-heading font-semibold text-xl text-ink leading-none mb-1">{value}</p>
              <p class="text-xs text-stone leading-snug">{label}</p>
            </div>
          </>
        ))}
      </div>

    </div>
  </div>

</section>
