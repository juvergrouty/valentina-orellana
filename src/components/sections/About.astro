---
import Icon from '../ui/Icon.astro';
---

<section class="bg-white border-t border-b border-dust overflow-hidden">
  <div class="container-site">
    <div class="flex flex-col md:flex-row items-stretch">

      <!-- Foto izquierda -->
      <div class="relative flex-shrink-0 md:w-[280px] h-[260px] md:h-auto">
        <img
          src="/images/valentina-retrato.jpg"
          alt="Ps. Valentina Orellana"
          class="w-full h-full object-cover object-top"
        />
        <!-- Degradado derecho para blend con el texto -->
        <div class="absolute inset-y-0 right-0 w-20 bg-gradient-to-r from-transparent to-white hidden md:block"></div>
      </div>

      <!-- Texto central -->
      <div class="flex flex-col justify-center py-10 px-8 lg:px-10 flex-1 border-r border-dust">
        <p class="label text-stone mb-3">Sobre mí</p>
        <div class="w-8 h-0.5 bg-forest/30 mb-5"></div>
        <p class="body-text mb-5 max-w-sm">
          Soy Valentina Orellana, psicóloga clínica con experiencia en terapia para adultos
          y parejas. Mi enfoque es cálido, cercano y basado en evidencia.
        </p>
        <a href="/sobre-mi"
           class="font-body text-sm text-forest tracking-wide flex items-center gap-2 hover:gap-3 transition-all duration-200 w-fit">
          Conocer más sobre mí
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>

      <!-- Stats — 3 columnas horizontales -->
      <div class="grid grid-cols-3 divide-x divide-dust flex-shrink-0 md:w-[420px]">
        {[
          { icon: 'users',   value: '+5 años',   label: 'acompañando a\npersonas y parejas' },
          { icon: 'shield',  value: '100%',       label: 'comprometida con\ncada proceso' },
          { icon: 'map-pin', value: 'Las Condes', label: 'y atención online\nen todo Chile' },
        ].map(({ icon, value, label }) => (
          <div class="flex flex-col items-center justify-center text-center px-4 py-10 gap-2">
            <div class="text-forest/50 mb-1">
              <Icon name={icon} size={22} />
            </div>
            <p class="font-heading font-semibold text-lg text-ink leading-none">{value}</p>
            <p class="body-sm leading-snug whitespace-pre-line">{label}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
