---
import { testimonials } from '../../data/services';
---

<!-- Testimonio destacado — home page -->
<section class="bg-review">
  <div class="container-site py-20 md:py-28">

    <!-- Cita principal (primera) -->
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-heading font-light text-6xl text-forest/40 leading-none mb-4">"</p>
      <blockquote class="font-heading font-light text-ink text-quote leading-relaxed mb-8">
        {testimonials[0].text}
      </blockquote>
      <div class="w-10 h-px bg-stone/20 mx-auto mb-5"></div>
      <p class="label">— {testimonials[0].name} · {testimonials[0].service}</p>
    </div>

    <!-- Otros dos testimonios -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-16 pt-14 border-t border-stone/20">
      {testimonials.slice(1).map((t) => (
        <div>
          <p class="body-text italic mb-5">"{t.text}"</p>
          <p class="label">— {t.name} · {t.service}</p>
        </div>
      ))}
    </div>

  </div>
</section>
