---
import { getCachedReviews } from '../../lib/googleReviews';

const cache    = await getCachedReviews();
const reviews  = (cache?.reviews ?? []).filter(r => r.text);
const featured = reviews[0] ?? null;
const others   = reviews.slice(1, 5);

function stars(n: number) {
  return Array.from({ length: 5 }, (_, i) => i < Math.round(n));
}
---

{featured && (
<!-- Reseñas reales de Google — home / opiniones -->
<section class="bg-review">
  <div class="container-site py-14 md:py-28">

    <!-- Reseña destacada -->
    <div class="max-w-3xl mx-auto text-center">
      <div class="flex justify-center gap-1 mb-5">
        {stars(featured.rating).map(on => (
          <svg width="18" height="18" viewBox="0 0 24 24" fill={on ? '#F5A623' : 'none'} stroke="#F5A623" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        ))}
      </div>
      <blockquote class="font-heading font-light text-ink text-quote leading-relaxed mb-8">
        "{featured.text}"
      </blockquote>
      <div class="w-10 h-px bg-stone/20 mx-auto mb-5"></div>
      <p class="label">— {featured.author} · Reseña de Google</p>
    </div>

    <!-- Otras reseñas -->
    {others.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-16 pt-14 border-t border-stone/20">
        {others.map((t) => (
          <div>
            <div class="flex gap-0.5 mb-3">
              {stars(t.rating).map(on => (
                <svg width="14" height="14" viewBox="0 0 24 24" fill={on ? '#F5A623' : 'none'} stroke="#F5A623" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <p class="body-text italic mb-4">"{t.text}"</p>
            <p class="label">— {t.author}</p>
          </div>
        ))}
      </div>
    )}

    {cache?.total && (
      <p class="text-center label text-stone mt-14">
        {cache.rating?.toFixed(1)} ★ · {cache.total} reseñas en Google
      </p>
    )}

  </div>
</section>
)}
