# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Flow.cl ───────────────────────────────────────────────────────────────────
# Obtén tus credenciales en: https://app.flow.cl → Integración → Credenciales
# Para pruebas locales usar las credenciales de SANDBOX
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_ENV=sandbox        # cambiar a "production" al hacer deploy

# ── Sitio ─────────────────────────────────────────────────────────────────────
# URL base del sitio (sin barra final)
# En local: http://localhost:4321
# Para pruebas con webhook de Flow: URL pública de ngrok (ngrok http 4321)
# En producción: https://tudominio.cl
PUBLIC_SITE_URL=http://localhost:4321

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=tu_contraseña_admin
ADMIN_SECRET=cadena_aleatoria_segura_para_la_cookie
